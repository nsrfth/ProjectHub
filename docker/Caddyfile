# SITE_HOST examples:
#   "taskhub.example.com"   -> custom cert (set TLS_DIRECTIVE, see below)
#   ":80"                   -> local HTTP only (dev / LAN), TLS_DIRECTIVE empty
#
# Production uses a wildcard cert provisioned externally (*.modalalco.com).
# The cert files are bind-mounted from the host into caddy_custom_certs at
# /etc/caddy/custom/. ACME/Let's Encrypt is NOT used there.

{$SITE_HOST} {
    encode zstd gzip

    # TLS is environment-driven so one Caddyfile serves both localhost and
    # production. TLS_DIRECTIVE is substituted textually at load time:
    #   - production: TLS_DIRECTIVE="tls /etc/caddy/custom/fullchain.pem /etc/caddy/custom/private.key"
    #   - localhost (SITE_HOST=:80): TLS_DIRECTIVE="" — plain HTTP, no cert.
    # A stray tls directive on an HTTP (:80) listener is a hard config error,
    # which is exactly why this can't be hardcoded.
    {$TLS_DIRECTIVE}

    # Security headers. HSTS is only meaningful on HTTPS but harmless on :80.
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "DENY"
        Referrer-Policy           "strict-origin-when-cross-origin"
        Permissions-Policy        "geolocation=(), microphone=(), camera=()"
        # Caddy adds Server header; strip it.
        -Server
    }

    # API: reverse proxy to backend. Use `handle` (not `handle_path`) so the
    # `/api` prefix is preserved — the backend mounts its routes under /api/*
    # and serves Swagger at /api/docs; handle_path would strip the prefix and
    # cause every /api request to 404.
    handle /api/* {
        reverse_proxy backend:4000
    }

    # index.html must never be served stale. It references hashed JS/CSS
    # filenames that change on every deploy; a stale copy served by the PWA
    # service worker loads the old JS bundle, which can silently fail against
    # a newer server version (empty teams list, empty dashboard, etc.).
    handle /index.html {
        root * /srv/www
        header Cache-Control "no-cache, must-revalidate"
        file_server
    }

    # Static SPA. Try file then fall back to index.html for client-side routing.
    handle {
        root * /srv/www
        try_files {path} /index.html
        file_server
    }
}
