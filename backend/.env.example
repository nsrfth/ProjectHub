# Local dev .env for the backend. Copy to .env (gitignored).
NODE_ENV=development
PORT=4000

DATABASE_URL=postgresql://taskhub:taskhub@localhost:5432/taskhub?schema=public
REDIS_URL=redis://localhost:6379

# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=dev_only_replace_me_with_a_long_random_string
JWT_REFRESH_SECRET=dev_only_replace_me_with_a_different_long_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

COOKIE_DOMAIN=
COOKIE_SECURE=false

CORS_ORIGINS=http://localhost:5173

UPLOAD_MAX_BYTES=10485760
UPLOAD_DIR=./uploads

AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW=1 minute
