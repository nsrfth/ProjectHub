// Prisma schema for TaskHub.
// See ARCHITECTURE.md for the rationale behind the GlobalRole/TeamRole split,
// the denormalized Task.teamId, and hashed refresh tokens.

generator client {
  provider      = "prisma-client-js"
  // "native" covers whichever host runs `prisma migrate dev` (Windows/macOS/glibc Linux).
  // "linux-musl-openssl-3.0.x" is required for the Alpine runtime image — without it
  // the engine defaults to the openssl-1.1.x binary, which Alpine 3.18+ doesn't ship.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GlobalRole {
  ADMIN
  MEMBER
}

enum TeamRole {
  MANAGER
  MEMBER
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
  ON_HOLD
}

// v1.91 (PMIS R1 — neutral core): project health as a RAG (Red/Amber/Green)
// signal for portfolio roll-up. Today this is a manual PM judgement; a later
// slice may derive it from schedule/cost variance and flip ragManual. GREEN is
// the migration default so every existing project stays valid with no backfill.
enum RagStatus {
  GREEN
  AMBER
  RED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  // v2.5.58: parked/blocked. Entering ON_HOLD requires an explanatory comment
  // (enforced in tasksService via statusCommentRequirement).
  ON_HOLD
  REVIEW
  // v1.87: a task that requires approval lands here when "completed" (moved to
  // DONE) by a non-finalizer — it waits for the designated approver (or a
  // manager/admin) to approve (→ DONE) or reject-with-reason (→ IN_PROGRESS).
  PENDING_APPROVAL
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// v2.1.1 (PMIS R1 supplement): controls how Task.percentComplete is interpreted.
// MANUAL = the stored value; FROM_CHILDREN = weighted leaf rollup at call time;
// FROM_STATUS = derived from the task's current status.
enum PercentCompleteMode {
  MANUAL
  FROM_CHILDREN
  FROM_STATUS
}

// v1.94 (PMIS R1 — neutral core): the Consulted / Informed legs of RACI.
// Responsible (Task.responsibleId) and Accountable (Project.accountableId)
// already exist as scalar fields; C and I are many-per-task, so they live in a
// join table (TaskRaci).
enum RaciRole {
  CONSULTED
  INFORMED
}

enum NotifyType {
  TASK_ASSIGNED
  TASK_COMMENT
  TASK_DUE
  MENTION
  TASK_STATUS
  // v1.29: a task you depended on completed and you now have zero
  // incomplete blockers. Recipient = assignee + responsible of the dependent.
  TASK_UNBLOCKED
  // v1.51: user group invitation for cross-team project access.
  GROUP_INVITE
  // v1.90: a project letter was referred (ارجاع) to you for ACTION or INFO.
  CORRESPONDENCE_REFERRAL
  // v2.5.28: a personal (standalone) task you own is coming due. Team-less —
  // see Notification.teamId (now nullable) and StandaloneTask.
  STANDALONE_TASK_DUE
  // v2.8 (Phase 3): a project-access grant awaits YOUR approval (you are the
  // unit manager / target team's manager), or a grant you issued was decided.
  GRANT_PENDING
  GRANT_DECIDED
  // v-next (cross-unit assignment workflow). ⚠ Native pg enum: adding values is
  // ALTER TYPE ... ADD VALUE, which cannot be used in the same transaction that
  // references it. Keep the migration that adds these standalone (no INSERT/
  // UPDATE using the value in the same file); nothing emits them until Slice 5.
  ASSIGNMENT_REQUESTED // approver: a request awaits your decision
  ASSIGNMENT_DECIDED // requester: approved / forwarded / assigned / declined
}

// v1.90: correspondence (دبیرخانه) module enums.
enum CorrespondenceDirection {
  INCOMING
  OUTGOING
  INTERNAL
}

enum CorrespondenceStatus {
  DRAFT
  SENT
  RECEIVED
  ARCHIVED
}

enum ContactType {
  PERSON
  ORG
}

enum ReferralKind {
  ACTION
  INFO
}

enum ReferralStatus {
  PENDING
  HANDLED
}

enum GroupAccessLevel {
  FULL
  READONLY
}

// v1.59: budget currency codes. IRR displays with 0 decimal places;
// EUR/USD with 2. Storage stays Decimal(18,2) for all currencies.
enum Currency {
  IRR
  EUR
  USD
}

// v1.95 (PMIS R0 — plumbing): FX reference rates for the multi-currency
// portfolio roll-up / EVM that the controls waves add (consumed from R4).
// Global reference data — a USD→IRR rate on a given date is the same for every
// team — so there is intentionally NO teamId. `rate` reads as "1 baseCurrency =
// <rate> quoteCurrency". Identity rows (base == quote, rate 1.0) are seeded in
// R4, not here. Scaffold only: nothing reads this table yet. If per-team rate
// overrides are ever needed, add a nullable teamId + widen the unique key.
model FxRate {
  id            String   @id @default(cuid())
  baseCurrency  Currency
  quoteCurrency Currency
  rate          Decimal  @db.Decimal(18, 8)
  asOf          DateTime @db.Date
  source        String?
  createdAt     DateTime @default(now())

  @@unique([baseCurrency, quoteCurrency, asOf])
  @@index([baseCurrency, quoteCurrency])
}

// v1.58: custom field types for team-scoped task metadata.
enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  SINGLE_SELECT
  MULTI_SELECT
  CHECKBOX
  PERSON
}

enum GroupInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

// v1.29: relationship kind on a TaskDependency edge.
//   FINISH_TO_START — the standard "blocker" edge: the dependent task
//     cannot move to IN_PROGRESS/DONE while the dependsOn task is incomplete
//     (gated by the tasks.dependencyEnforcement InstanceSetting).
//   RELATES_TO     — informational link only; status guard ignores it.
enum DependencyType {
  FINISH_TO_START
  RELATES_TO
  // v1.83: scheduling types enforced via status rules (not dates).
  // SS: B can't START until A has started. FF: B can't FINISH until A has.
  START_TO_START
  FINISH_TO_FINISH
}

// v2.1 (PMIS R5 — scheduling engine): lag/lead on dependency edges.
enum LagUnit {
  DAY
  HOUR
}

enum CalendarMode {
  WORKING
  CALENDAR
}

// v2.1 (PMIS R5): per-resource calendars (R6 consumes RESOURCE scope).
enum CapacityCalendarScope {
  TEAM
  RESOURCE
  PROJECT
}

enum CalendarExceptionKind {
  HOLIDAY
  WORKDAY
}

enum DirectoryKind {
  LDAP
  // SCIM placeholder for Phase 2B — kept in the same enum so a SCIM directory
  // can reuse the same Directory row + group mappings.
  SCIM
}

// How the user signs in. LOCAL = argon2 password in TaskHub; LDAP = directory
// bind; SCIM = provisioned via SCIM (no password login).
enum AuthSource {
  LOCAL
  LDAP
  SCIM
}

// v1.10: per-user display calendar. Affects every place the frontend renders
// a calendar date or timestamp. Default SHAMSI matches the pre-v1.10
// behaviour (TaskHub is Persian-leaning by default); switching to GREGORIAN
// is a one-checkbox change on Settings → Preferences.
enum CalendarPreference {
  SHAMSI
  GREGORIAN
}

// v1.13: per-user theme. LIGHT default — pre-v1.13 the SPA shipped
// light-only, so existing users see no surprise.
enum ThemePreference {
  LIGHT
  DARK
  SYSTEM
  MIDNIGHT
  SOLARIZED
  HIGH_CONTRAST
  NORD
  INDIGO
  VIBRANT
  SUNSET
  AGGRESSIVE
  OCEAN
}

enum HolidaySource {
  MANUAL
  IMPORT
  SYNC
}

// v1.13: per-user UI language. EN is the canonical key source; FA covers
// the most-visible surfaces in this release. Strings without an FA entry
// fall back to EN.
enum LanguagePreference {
  EN
  FA
}

enum TimeFormat {
  H12
  H24
}

// External identity provider. Phase 2A handles LDAP; SCIM in 2B reuses this.
// One Directory binds many Users (via User.directoryId/externalId).
model Directory {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  kind        DirectoryKind @default(LDAP)
  // LDAP connection details — ignored for non-LDAP kinds.
  host        String?
  port        Int?
  useTLS      Boolean       @default(true)
  // When true, LDAPS / STARTTLS skips TLS certificate chain verification.
  // Use only with internal AD CAs; prefer installing the CA in the container.
  tlsInsecure Boolean       @default(false)
  bindDN      String?
  // Bind password ciphertext (AES-256-GCM via lib/crypto). NEVER surface in
  // any API response — Zod response schemas must not include this field.
  bindPasswordEnc String?
  baseDN      String?
  userFilter  String?  // e.g. "(objectClass=person)"
  groupFilter String?  // e.g. "(objectClass=groupOfNames)"
  // Attribute names — different LDAPs use different conventions.
  userIdAttr        String  @default("uid")   // AD users typically use sAMAccountName.
  emailAttr         String  @default("mail")
  nameAttr          String  @default("cn")
  groupMemberAttr   String  @default("member")
  // Just-in-time provisioning: when true, a successful LDAP bind creates a
  // local User row if one doesn't exist yet.
  allowJIT          Boolean @default(true)
  // Roll group memberships into TaskHub roles on every login.
  syncRolesFromGroups Boolean @default(false)
  // v2.6 (Phase 0a): scheduled directory sync. DELIBERATELY separate from
  // syncRolesFromGroups, which gates login-time mapping only. Overloading that
  // flag would silently start a nightly directory walk on every install that
  // had enabled login-time mapping — a behaviour change on upgrade.
  // A directory can be sync-enabled without changing login behaviour, and the
  // reverse. See docs/DIRECTORY_SYNC.md §9.
  syncEnabled       Boolean @default(false)
  // Skip pass 2 (per-mapped-group member expansion) when memberOf is known to
  // be reliable — true on Active Directory, false on OpenLDAP without the
  // memberof overlay. Defaults false: a missing group is an under-grant, and
  // under-grants are exactly what blocks assignment.
  syncTrustMemberOf Boolean @default(false)
  lastSyncAt        DateTime?
  lastSyncStatus    String?   // 'OK' | 'ABORTED' | 'SKIPPED'
  lastSyncSummary   Json?     // DirectorySyncDirectoryResult, for the admin UI
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  users         User[]                  @relation("UserDirectory")
  teams         Team[]                  @relation("TeamDirectory")
  groupMappings DirectoryGroupMapping[]
  scimCredential ScimCredential?
}

// One-time 2FA recovery code. The raw code is shown to the user exactly once
// at generation; only the sha256 hash is persisted. `usedAt` survives the
// row to make burn-on-first-use observable in audit.
model RecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String    @unique
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Bearer credential an external IdP uses to push SCIM 2.0 provisioning calls
// at this Directory. One credential per Directory — re-generation overwrites
// the row. `tokenHash` is sha256(rawToken); the raw token is shown to the
// admin exactly once at generation time and never persisted.
model ScimCredential {
  id          String    @id @default(cuid())
  directoryId String    @unique
  tokenHash   String    @unique
  // Human-readable label shown in the UI (e.g. "Okta production").
  name        String
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  directory   Directory @relation(fields: [directoryId], references: [id], onDelete: Cascade)

  @@index([directoryId])
}

// External group DN → TaskHub role. Phase 2A supports global roles + team-
// scoped manager/member assignment. teamId is nullable: when set, the
// mapping grants membership in that specific team; when null, it grants the
// listed globalRole instance-wide.
model DirectoryGroupMapping {
  id              String     @id @default(cuid())
  directoryId     String
  externalGroupDn String
  globalRole      GlobalRole?
  teamId          String?
  teamRole        TeamRole?
  // v1.30.6 (S-6 / S-7): explicit custom-role pointer. When set, the
  // LDAP / SCIM provisioning path stamps THIS role onto the
  // TeamMembership it creates. When null, the path falls back to the
  // team's system Manager / Member role matching `teamRole`. SetNull
  // on Role delete so removing a role just degrades the mapping to
  // "use system Member" — doesn't cascade-delete the mapping itself.
  roleId          String?
  role            Role?      @relation(fields: [roleId], references: [id], onDelete: SetNull)

  // v2.6 (Phase 1A), decision D-3 = security groups.
  //
  // D-3 asked what AD anchors unit membership to: security groups, OU DNs, or
  // user attributes. Security groups won because this table is ALREADY
  // DN-keyed — so the anchor needs one nullable column here rather than a
  // separate mapping table with its own sync semantics. The OU/attribute
  // options would each have required that second table.
  //
  // Null on every existing row: a mapping that grants team membership but no
  // unit is still perfectly valid, and that is what all of them are today.
  // SetNull on group delete, matching `roleId` above — removing a unit
  // degrades the mapping to "team membership only" rather than cascading it
  // away and silently dropping the team grant too.
  userGroupId     String?
  userGroup       UserGroup? @relation(fields: [userGroupId], references: [id], onDelete: SetNull)

  // v2.9 (Phase 4, D-3): the org node this AD group places its members into.
  // Same anchor pattern as userGroupId above; SetNull so deleting an org node
  // degrades the mapping rather than cascading it away.
  orgUnitId       String?
  orgUnit         OrgUnit?   @relation(fields: [orgUnitId], references: [id], onDelete: SetNull)

  directory       Directory  @relation(fields: [directoryId], references: [id], onDelete: Cascade)

  @@unique([directoryId, externalGroupDn])
  @@index([directoryId])
  @@index([roleId])
  @@index([userGroupId])
}

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  // Nullable as of v1.4 — LDAP-managed users have no local password. Local
  // users continue to set this at register time. authService gates which
  // flow to run based on directoryId.
  passwordHash    String?
  name            String
  globalRole      GlobalRole @default(MEMBER)
  // Set when the user is owned by an external directory. null = local user.
  directoryId     String?
  // External stable identifier (LDAP DN, SCIM externalId). Unique together
  // with directoryId so multiple directories can use overlapping IDs.
  externalId      String?
  // Explicit auth backend — backfilled from directoryId + Directory.kind for
  // existing rows. LOCAL users have directoryId=null.
  authSource      AuthSource @default(LOCAL)
  // LDAP profile fields (synced on login / admin refresh). Null for LOCAL users.
  ldapUsername    String?
  userPrincipalName String?
  department      String?
  jobTitle        String?
  managerName     String?
  ldapSyncedAt    DateTime?
  // Local-password policy tracking (ignored for LDAP/SCIM users).
  passwordChangedAt   DateTime?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  // Set when the user is soft-disabled. Login + refresh both reject when
  // this is non-null. SCIM deprovision (PATCH active=false) sets this and
  // revokes outstanding refresh tokens; reprovision (active=true) clears it.
  disabledAt      DateTime?
  // v1.49: built-in system identity (admin@taskhub.local). Hidden from all
  // user-facing lists; auto-assigned as manager on every team.
  isSystemUser    Boolean    @default(false)
  // TOTP 2FA (Phase 2C). totpSecretEnc holds the AES-256-GCM ciphertext of
  // the shared secret; totpEnabled flips true only after the user confirms
  // a code during setup. Both clear on disable.
  totpSecretEnc   String?
  totpEnabled     Boolean    @default(false)
  // v1.10: display calendar preference. Read by the frontend at login,
  // mirrored into localStorage, and applied to every date/timestamp the
  // UI renders + the date pickers.
  calendarPreference CalendarPreference @default(SHAMSI)
  // v1.13: per-user theme (LIGHT default) + UI language (EN default).
  // Mirrored to localStorage on login; the SPA applies them via
  // <html class="dark"> and <html dir="rtl" lang="fa"> respectively.
  themePreference    ThemePreference    @default(LIGHT)
  languagePreference LanguagePreference @default(EN)
  // v1.63: timestamp display — IANA zone for category-(b) instants only;
  // calendar dates (dueDate, etc.) stay UTC-midnight zone-neutral.
  timeZone           String?
  timeFormat         TimeFormat         @default(H24)
  dualCalendar       Boolean            @default(false)
  // v1.65: hours before dueDate to emit TASK_DUE (assignee preference).
  reminderLeadHours  Int?               @default(24)
  emailVerifiedAt DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  directory       Directory? @relation("UserDirectory", fields: [directoryId], references: [id], onDelete: SetNull)

  @@unique([directoryId, externalId])
  @@index([directoryId])

  memberships    TeamMembership[]
  // v2.6 (Phase 2): grants this user issued (audit trail, not grants they hold —
  // those are found by subjectId, which is polymorphic and therefore unrelated).
  issuedProjectGrants ProjectAccessGrant[] @relation("ProjectGrantsIssued")
  // v2.9 (Phase 4): business-dimension memberships.
  orgMemberships OrgUnitMembership[]
  ownedProjects  Project[]        @relation("ProjectOwner")
  accountableForProjects Project[] @relation("ProjectAccountable")
  managedOrgUnits OrgUnit[]       @relation("OrgUnitManager")
  assignedTasks  Task[]           @relation("TaskAssignee")
  createdTasks   Task[]           @relation("TaskCreator")
  responsibleForTasks    Task[]    @relation("TaskResponsible")
  approverForTasks       Task[]    @relation("TaskApprover")
  // v2.0 (PMIS R4): time tracking + rate cards. Audit ids (decidedById on a
  // period, createdById on an actual, submitted/decidedById on an expense) are
  // plain scalars, not relations — they're observability stamps, not FKs.
  rateCards        RateCard[]
  timesheetPeriods TimesheetPeriod[]
  timeEntries      TimeEntry[]      @relation("TimeEntryUser")
  responsibleForSubtasks Subtask[] @relation("SubtaskResponsible")
  // v1.42: Subtask assignee — distinct from responsible (RACI). Anyone
  // with project access can change this; SetNull on user delete.
  assignedSubtasks      Subtask[] @relation("SubtaskAssignee")
  deletedTasks    Task[]    @relation("TaskDeletedBy")
  raciTasks       TaskRaci[]
  capturedBaselines ProjectBaseline[] @relation("BaselineCapturedBy")
  deletedComments Comment[] @relation("CommentDeletedBy")
  comments       Comment[]
  activities     Activity[]
  notifications  Notification[]
  // v2.5.28: personal tasks owned by this user (Option C — isolated model).
  standaloneTasks StandaloneTask[] @relation("UserStandaloneTasks")
  refreshTokens      RefreshToken[]
  passwordResets     PasswordReset[]
  emailVerifications EmailVerification[]
  uploads            Attachment[]
  recoveryCodes      RecoveryCode[]
  apiTokens          ApiToken[]
  passwordHistory    PasswordHistory[]
  projectBuckets     UserProjectBucket[]
  userGroupMembers   UserGroupMember[]
  groupInvitesSent   UserGroupMember[] @relation("GroupInvitesSent")
  customFieldValues  CustomFieldValue[] @relation("CustomFieldPerson")
  holidaysCreated    Holiday[]          @relation("HolidayCreatedBy")
  ownedDashboards    Dashboard[]        @relation("DashboardOwner")
  createdIntakeForms IntakeForm[]       @relation("IntakeFormCreator")
  // v1.86: per-project full-edit delegations granted to / by this user.
  projectEditDelegations ProjectEditDelegate[] @relation("ProjectEditDelegateUser")
  projectEditDelegatesGranted ProjectEditDelegate[] @relation("ProjectEditDelegateGrantedBy")
  // v1.90: correspondence (دبیرخانه) module back-relations.
  contactsCreated         Contact[]                @relation("ContactCreatedBy")
  correspondenceCreated   Correspondence[]         @relation("CorrespondenceCreatedBy")
  correspondenceDeleted   Correspondence[]         @relation("CorrespondenceDeletedBy")
  correspondenceReferralsReceived CorrespondenceReferral[] @relation("ReferralRecipient")
  correspondenceReferralsSent     CorrespondenceReferral[] @relation("ReferralReferredBy")
  // v2.2 (PMIS R6): linked team-member resources.
  managedResources    Resource[]
  // v2.4 (PMIS R8): record framework back-relations.
  pmisRecordsAssigned PmisRecord[]        @relation("PmisRecordAssignee")
  pmisRecordsCreated  PmisRecord[]        @relation("PmisRecordCreatedBy")
  pmisRecordComments  PmisRecordComment[] @relation("PmisRecordCommentAuthor")
  // v2.5 (PMIS R9): specialized lifecycle back-relations.
  risksOwned          RiskRecord[]   @relation("RiskOwner")
  risksCreated        RiskRecord[]   @relation("RiskCreatedBy")
  crsSubmitted        ChangeRequest[] @relation("CrSubmittedBy")
  crsDecided          ChangeRequest[] @relation("CrDecidedBy")
  contractsCreated    Contract[]     @relation("ContractCreatedBy")
  posCreated          PurchaseOrder[] @relation("PoCreatedBy")
  ncrsCreated         QualityNcr[]   @relation("NcrCreatedBy")

  @@index([email])
}

// v1.45: per-user project organization buckets on the Projects page.
// Personal views only — no effect on project data or permissions.
model UserProjectBucket {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  color       String?
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items UserProjectBucketItem[]

  @@unique([userId, name])
  @@index([userId, position])
}

model UserProjectBucketItem {
  id        String   @id @default(cuid())
  bucketId  String
  bucket    UserProjectBucket @relation(fields: [bucketId], references: [id], onDelete: Cascade)
  userId    String
  projectId String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([bucketId, projectId])
  @@index([bucketId, position])
  @@index([userId, projectId])
}

// Previous password hashes for local users — enforces password history policy.
model PasswordHistory {
  id           String   @id @default(cuid())
  userId       String
  passwordHash String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// Security and server configuration audit trail (distinct from task Activity).
model SecurityAuditEvent {
  id        String   @id @default(cuid())
  kind      String
  actorId   String?
  details   Json
  createdAt DateTime @default(now())

  @@index([kind, createdAt])
  @@index([createdAt])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  // Store SHA-256 of the raw token; a DB leak should not yield usable sessions.
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  // v1.30.5 (S-4): rotation chains share a familyId. On first issue
  // (login / register / 2FA-login) familyId = self.id. On rotation the
  // newly issued row inherits the presented token's familyId. When a
  // refresh sees an ALREADY-revoked token (replay of a token already
  // rotated away), the whole family is revoked — that's the canonical
  // response to detected token theft.
  familyId  String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailVerification {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Team {
  id            String           @id @default(cuid())
  name          String
  slug          String           @unique
  // When set, the team's membership is synthesized from LDAP/SCIM group
  // mappings rather than manually managed. Manager-driven invites are
  // disabled in the UI for directory-managed teams.
  directoryId   String?
  // v1.12: per-team accent colour shown on kanban cards + calendar views.
  // Hex like "#3b82f6"; null = default slate. Admins / team managers set it.
  color           String?
  // v1.59: pre-fills budget currency on newly created projects (editable per project).
  defaultCurrency Currency         @default(IRR)
  // v1.95 (PMIS R0): currency this team's portfolio roll-ups / EVM report in
  // (consumed from R4). Null → fall back to defaultCurrency. Deliberately
  // distinct from defaultCurrency (which only pre-fills new project budgets).
  reportingCurrency Currency?
  // v1.98 (PMIS R2): the team's default project profile (defaulting carrier:
  // group ▸ team ▸ system NEUTRAL). Backfilled to system NEUTRAL for existing
  // teams; new teams are stamped with NEUTRAL at create. SetNull on profile
  // delete.
  defaultProfileId String?
  createdAt       DateTime         @default(now())
  memberships   TeamMembership[]
  projects      Project[]
  ownedProfiles ProjectProfile[] @relation("TeamOwnedProfiles")
  defaultProfile ProjectProfile? @relation("TeamDefaultProfile", fields: [defaultProfileId], references: [id], onDelete: SetNull)
  labels        Label[]
  roles         Role[]
  notifications Notification[]
  activities    Activity[]       @relation("TeamActivity")
  webhooks      Webhook[]
  userGroups    UserGroup[]
  // v2.5.58: projects shared INTO this team (whole-team shares).
  projectShares ProjectTeamShare[] @relation("ProjectSharesForTeam")
  customFields  CustomFieldDefinition[]
  automationRules AutomationRule[]
  dashboards    Dashboard[]
  intakeForms   IntakeForm[]
  contacts                Contact[]
  correspondence          Correspondence[]
  correspondenceReferrals CorrespondenceReferral[]
  orgUnitLinks            TeamOrgUnit[]
  // v-next: cross-unit assignment requests scoped to this division.
  taskAssignmentRequests  TaskAssignmentRequest[]
  // v2.0 (PMIS R4 — cost control + time tracking).
  rateCards          RateCard[]
  timesheetPeriods   TimesheetPeriod[]
  timeEntries        TimeEntry[]
  costAccounts       CostAccount[]
  budgetLines        BudgetLine[]
  commitments        Commitment[]
  actualCostEntries  ActualCostEntry[]
  expenses           Expense[]
  capacityCalendars  CapacityCalendar[]
  // v2.2 (PMIS R6 — resource management).
  resources           Resource[]
  skills              Skill[]
  resourceAssignments ResourceAssignment[]
  // v2.3 (PMIS R7 — EVM).
  evmSnapshots        EvmSnapshot[]
  // v2.4 (PMIS R8 — record framework).
  recordTypes         PmisRecordType[]
  pmisRecords         PmisRecord[]
  // v2.5 (PMIS R9 — specialized lifecycle).
  risks               RiskRecord[]
  changeRequests      ChangeRequest[]
  vendors             Vendor[]
  contracts           Contract[]
  purchaseOrders      PurchaseOrder[]
  qualityNcrs         QualityNcr[]
  directory     Directory?       @relation("TeamDirectory", fields: [directoryId], references: [id], onDelete: SetNull)

  @@index([directoryId])
}

model TeamMembership {
  id       String   @id @default(cuid())
  userId   String
  teamId   String
  // v1.23: legacy enum, kept as fallback for one release while migration
  // backfills the new roleId. v1.24 drops this column. Service layer reads
  // roleId first; falls back to this field when roleId is null.
  role     TeamRole @default(MEMBER)
  // v1.23: custom role assignment. Nullable initially so the migration can
  // create the column, backfill, then later releases enforce NOT NULL.
  roleId   String?
  joinedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  customRole Role?  @relation("MembershipRole", fields: [roleId], references: [id], onDelete: SetNull)

  @@unique([userId, teamId])
  @@index([teamId])
  @@index([roleId])
}

// v1.23: per-team custom role. Two seed roles per team ("Manager", "Member")
// land with `isSystem = true` — editable but undeletable. Admins create
// additional roles freely.
model Role {
  id          String   @id @default(cuid())
  teamId      String
  name        String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  memberships TeamMembership[] @relation("MembershipRole")
  // v1.30.6 (S-6 / S-7): directory mappings pointing at this custom role.
  directoryMappings DirectoryGroupMapping[]

  @@unique([teamId, name])
  @@index([teamId])
}

// v1.23: role × permission junction. The `permission` field stores one of
// the constants from lib/permissions.ts; the service layer rejects anything
// else on write. Permissions themselves are NOT a database table — they're
// bound to code paths.
model RolePermission {
  roleId     String
  permission String

  role       Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permission])
}

model Project {
  id            String        @id @default(cuid())
  teamId        String
  ownerId       String?
  // v1.17: "Accountable" in RACI terms — the person on the hook for this
  // project's outcomes. Distinct from the owner (often the manager who
  // maintains it). Nullable so the field stays optional; SetNull on user
  // delete so we don't cascade-nuke projects.
  accountableId String?
  name          String
  // v1.92 (PMIS R1 — neutral core): optional human-facing project code, unique
  // within the team when set (e.g. "EPC-014"). Nullable so existing projects
  // stay valid with no backfill; the org assigns codes as it adopts them.
  code          String?
  description   String?
  status        ProjectStatus @default(ACTIVE)
  // v1.41: optional budget fields. DECIMAL(18,2): 16 digits before the
  // decimal point + 2 after (currency-grade precision in any unit).
  // Non-negative is enforced by DB CHECK + Zod; nullable so existing
  // projects stay valid without backfill.
  plannedBudget  Decimal?  @db.Decimal(18, 2)
  // v1.59: currency label for budget amounts (no conversion). Task budgets
  // inherit this currency — tasks do not store their own currency column.
  budgetCurrency Currency    @default(IRR)
  // v1.72: optional project schedule window (UTC-midnight calendar dates).
  startDate      DateTime?
  endDate        DateTime?
  // v1.90: correspondence (دبیرخانه) module toggle — a global admin enables the
  // per-project letters register from Settings → Correspondence module.
  correspondenceEnabled Boolean @default(false)
  // v2.5.58: freeze the project PLAN. While true, plan dates are locked for
  // everyone (project start/end, task start/due/planned/baseline, subtask
  // start/end, recurrence spawning); reality capture stays open (completedAt,
  // actualStart/actualEnd, status, progress). Toggled by owner / global ADMIN.
  datesFrozen Boolean @default(false)
  // v1.91 (PMIS R1 — neutral core): project health for portfolio roll-up.
  // ragStatus defaults GREEN (no backfill needed); ragReason is an optional
  // free-text note. healthUpdatedAt is stamped whenever the health is set so
  // the portfolio view can flag stale health. Set via PUT .../projects/:id/health
  // by anyone with project WRITE access.
  ragStatus      RagStatus @default(GREEN)
  ragReason      String?
  healthUpdatedAt DateTime?
  // v1.96 (PMIS R1 — neutral core): nearest-portfolio attach point. Plain
  // nullable id for now — the OrgUnit table + FK land in R3 (Portfolio). Null =
  // unattached (invisible to portfolio roll-ups). Indexed for the R3 subtree
  // aggregations.
  orgUnitId      String?
  // v1.98 (PMIS R2 — project profiles): the profile snapshotted onto this
  // project at create (profileId + the version it was at), plus project-level
  // overrides layered on the profile's module settings at read time. All
  // nullable/additive: existing projects backfill to system NEUTRAL v1 (all
  // modules off = today's behaviour exactly). profileOverrides is a JSON map of
  // moduleKey → partial { enabled, requiredFields, defaults, config }.
  profileId        String?
  profileVersion   Int?
  profileOverrides Json?
  // v2.1 (PMIS R5): bumped when schedule-shaping data changes (task dates,
  // dependencies, milestones) so on-demand CPM cache keys stay fresh.
  scheduleVersion Int           @default(0)
  createdAt      DateTime  @default(now())
  updatedAt     DateTime      @updatedAt
  team          Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  capacityCalendars CapacityCalendar[]
  orgUnit       OrgUnit?      @relation(fields: [orgUnitId], references: [id], onDelete: SetNull)
  profile       ProjectProfile? @relation("ProjectAssignedProfile", fields: [profileId], references: [id], onDelete: SetNull)
  // ownerId is nullable + SetNull so admins can delete a user without
  // cascading the deletion to every project they own. The project then shows
  // "owner: (deleted user)" in the UI until a manager reassigns it.
  owner         User?         @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  accountable   User?         @relation("ProjectAccountable", fields: [accountableId], references: [id], onDelete: SetNull)
  tasks         Task[]
  groupGrants   ProjectGroupGrant[]
  // v2.6 (Phase 2): the unified grant table. Coexists with groupGrants /
  // teamShares below for the whole dual-read period — those stay authoritative
  // until the flag reaches `on`, and are only dropped in Phase 6.
  accessGrants  ProjectAccessGrant[]
  // v2.5.58: whole-team shares (guest teams this project is mounted into).
  teamShares    ProjectTeamShare[]
  editDelegates ProjectEditDelegate[]
  intakeForms   IntakeForm[]
  labels        ProjectLabel[]
  correspondence        Correspondence[]
  correspondenceCounters CorrespondenceCounter[]
  // v-next: cross-unit assignment requests against this project's tasks.
  taskAssignmentRequests TaskAssignmentRequest[]
  baselines             ProjectBaseline[]
  // v2.0 (PMIS R4 — cost control + time tracking).
  timeEntries        TimeEntry[]
  costAccounts       CostAccount[]
  budgetLines        BudgetLine[]
  commitments        Commitment[]
  actualCostEntries  ActualCostEntry[]
  expenses           Expense[]
  // v2.2 (PMIS R6 — resource management).
  resourceAssignments ResourceAssignment[]
  // v2.3 (PMIS R7 — EVM).
  evmSnapshots        EvmSnapshot[]
  // v2.4 (PMIS R8 — record framework).
  pmisRecords         PmisRecord[]
  // v2.5 (PMIS R9 — specialized lifecycle).
  risks               RiskRecord[]
  changeRequests      ChangeRequest[]
  contracts           Contract[]
  purchaseOrders      PurchaseOrder[]
  qualityNcrs         QualityNcr[]

  // v1.30: tsvector for full-text search. See Task.searchVector for
  // rationale + lifecycle (managed by raw SQL, never read via Prisma).
  // Unsupported(...) auto-excludes the column from the Prisma client; the
  // SearchService talks to it via $queryRaw only.
  searchVector Unsupported("tsvector")?

  @@unique([teamId, code])
  @@index([teamId, status])
  @@index([teamId, startDate])
  @@index([ownerId])
  @@index([accountableId])
  @@index([orgUnitId])
  @@index([profileId])
}

// v1.96 (PMIS R1 — neutral core): how a captured baseline came to be. R1 only
// ever writes MANUAL; CHANGE_REQUEST is reserved for R9 change-control (an
// approved change is the sanctioned path to a new baseline) and is declared
// now so that wave needs no enum migration.
enum BaselineSource {
  MANUAL
  CHANGE_REQUEST
}

// v1.96 (PMIS R1 — neutral core): a formal project schedule baseline — an
// immutable snapshot of every live task's planned/baseline dates + progress at
// capture time, so later variance/EVM reporting can compare "now" against a
// frozen plan. The per-task detail lives in the `snapshot` JSON for R1; R5
// formalizes it into a `BaselineEntry` table. Exactly one baseline per project
// is `isCurrent` (capturing a new one flips the rest false in a transaction).
// teamId is denormalized (multi-tenancy invariant) so portfolio queries never
// join through Project.
model ProjectBaseline {
  id           String         @id @default(cuid())
  projectId    String
  teamId       String
  name         String
  source       BaselineSource @default(MANUAL)
  isCurrent    Boolean        @default(true)
  snapshot     Json
  capturedById String?
  capturedAt   DateTime       @default(now())

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  capturedBy User?   @relation("BaselineCapturedBy", fields: [capturedById], references: [id], onDelete: SetNull)
  // v2.1 (PMIS R5): formal per-task baseline bars (replaces JSON-only snapshot
  // for Gantt compare/variance; snapshot JSON kept for back-compat).
  entries    BaselineEntry[]

  @@index([projectId, isCurrent])
  @@index([teamId])
}

// v2.1 (PMIS R5): one task's frozen schedule window inside a ProjectBaseline.
model BaselineEntry {
  id         String   @id @default(cuid())
  baselineId String
  taskId     String
  start      DateTime?
  end        DateTime?

  baseline ProjectBaseline @relation(fields: [baselineId], references: [id], onDelete: Cascade)
  task     Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([baselineId, taskId])
  @@index([baselineId])
  @@index([taskId])
}

// v2.1 (PMIS R5): generalized capacity calendar (TEAM scope mirrors the
// existing weekend + Holiday rows via WorkingDayCalendar today; RESOURCE/PROJECT
// scopes land with R6). Scaffold table — CPM still reads WorkingDayCalendar.
model CapacityCalendar {
  id           String                @id @default(cuid())
  scope        CapacityCalendarScope
  teamId       String?
  projectId    String?
  workdayHours Decimal?              @default(8) @db.Decimal(4, 2)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  team       Team?                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project    Project?             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  exceptions CalendarException[]
  // v2.2 (PMIS R6): resources using this calendar.
  resources  Resource[]

  @@index([teamId])
  @@index([projectId])
}

model CalendarException {
  id         String                @id @default(cuid())
  calendarId String
  date       DateTime              @db.Date
  kind       CalendarExceptionKind
  hours      Decimal?              @db.Decimal(4, 2)
  createdAt  DateTime              @default(now())

  calendar CapacityCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  @@unique([calendarId, date])
}

// v1.98 (PMIS R2 — project profiles): a profile is BUILTIN (system-seeded,
// immutable) or CUSTOM (team-authored). System built-ins are the four
// cross-industry presets (NEUTRAL/IT/EPC/OPERATIONS); teams clone + tweak them
// as CUSTOM profiles.
enum ProfileKind {
  BUILTIN
  CUSTOM
}

// v1.98 (PMIS R2): SYSTEM profiles (teamId null) are the global built-ins
// visible to every team; TEAM profiles belong to one team.
enum ProfileOwnerScope {
  SYSTEM
  TEAM
}

// v1.98 (PMIS R2): a CUSTOM profile is editable only while DRAFT; PUBLISHED is
// the assignable, immutable state (editing a published profile = clone to a new
// draft so live projects that snapshot a version never silently mutate);
// DEPRECATED hides it from new assignments without breaking projects already
// pinned to it. The four system built-ins ship PUBLISHED.
enum ProfileStatus {
  DRAFT
  PUBLISHED
  DEPRECATED
}

// v1.98 (PMIS R2 — project profiles): a pluggable industry profile that toggles
// the optional PMIS modules (lib/moduleRegistry) on top of the always-on
// neutral core. Profile gating is ADDITIVE to RBAC — it can hide a capability a
// role grants, never grant one a role lacks. A project snapshots a profile
// (profileId + profileVersion) at create so re-publishing never mutates live
// projects; `profileOverrides` on the project layer on top at read time.
model ProjectProfile {
  id   String @id @default(cuid())
  // Stable machine key. Unique per (ownerScope, teamId, key) — enforced by a
  // partial unique index in the migration (system keys are globally unique;
  // a team's keys are unique within that team), which Prisma can't express, so
  // @@unique is intentionally omitted here.
  key  String
  name String
  kind       ProfileKind       @default(CUSTOM)
  ownerScope ProfileOwnerScope @default(TEAM)
  // Null for SYSTEM built-ins; set for TEAM-owned profiles.
  teamId     String?
  version    Int               @default(1)
  status     ProfileStatus     @default(DRAFT)
  // Lineage: the profile this one was cloned from (null for built-ins + the
  // first hand-authored profile). SetNull so deleting the ancestor doesn't
  // cascade the clone away.
  basedOnProfileId String?
  createdById      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  team            Team?            @relation("TeamOwnedProfiles", fields: [teamId], references: [id], onDelete: Cascade)
  basedOnProfile  ProjectProfile?  @relation("ProfileLineage", fields: [basedOnProfileId], references: [id], onDelete: SetNull)
  derivedProfiles ProjectProfile[] @relation("ProfileLineage")
  moduleSettings  ProfileModuleSetting[]
  // Back-relations from the three "carriers" that point at a profile.
  projectsUsing    Project[]   @relation("ProjectAssignedProfile")
  teamsDefaulting  Team[]      @relation("TeamDefaultProfile")
  groupsDefaulting UserGroup[] @relation("GroupDefaultProfile")

  @@index([teamId])
  @@index([ownerScope, status])
  @@index([key])
}

// v1.98 (PMIS R2): one row per (profile, optional module). `moduleKey` is
// validated against lib/moduleRegistry (isModuleKey) at the service layer.
// `requiredFields` references existing team CustomFieldDefinition ids the
// profile marks required; `defaults`/`config` are free-form per-module bags the
// consuming Wave-B/C module interprets.
model ProfileModuleSetting {
  id             String  @id @default(cuid())
  profileId      String
  moduleKey      String
  enabled        Boolean @default(false)
  requiredFields Json    @default("[]")
  defaults       Json    @default("{}")
  config         Json    @default("{}")

  profile ProjectProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, moduleKey])
  @@index([profileId])
}

// v1.99 (PMIS R3 — portfolio / program): typed hierarchy above Team.
// HOLDING → (COMPANY) → PORTFOLIO → PROGRAM. Projects attach to any node via
// Project.orgUnitId; roll-up reports aggregate the subtree (materialized
// `path` prefix). Teams stay the security boundary — TeamOrgUnit is an
// optional hint for default-attachment suggestions only.
// v2.5.27: COMPANY (legal subsidiary) added between HOLDING and PORTFOLIO —
// reporting-only, no RBAC; see lib/orgUnitTree.ts for placement rules.
enum OrgUnitType {
  HOLDING
  COMPANY
  PORTFOLIO
  PROGRAM
  // v2.9 (Phase 4, decision D-8): a physical site (KVSM, KVSS, Nabdaneh, BIK,
  // KDJ…). Its own vocabulary rather than PROGRAM-as-site, because a site is
  // a place people belong to and a program is a thing money flows through —
  // conflating them pollutes every roll-up that groups by type.
  SITE
}

model OrgUnit {
  id        String       @id @default(cuid())
  parentId  String?
  type      OrgUnitType
  name      String
  // Machine code, unique within the parent (root parentId null).
  code      String
  // Materialized ancestry path: "/{id}" for root, "{parent.path}/{id}" for
  // descendants. Used for subtree roll-ups (startsWith prefix match).
  path      String
  managerId String?
  // Optional reporting currency for this subtree (R4 consumes it).
  currency  Currency?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  parent    OrgUnit?     @relation("OrgUnitTree", fields: [parentId], references: [id], onDelete: Restrict)
  children  OrgUnit[]    @relation("OrgUnitTree")
  manager   User?        @relation("OrgUnitManager", fields: [managerId], references: [id], onDelete: SetNull)
  projects  Project[]
  teamLinks TeamOrgUnit[]
  // v2.9 (Phase 4): people who belong to this org node.
  members   OrgUnitMembership[]
  // v2.9 (Phase 5): standing grant policies anchored at this node.
  grantPolicies OrgUnitGrantPolicy[] @relation("PolicyAnchor")
  // v2.9 (Phase 4, D-3): directory mappings placing people into this node.
  directoryMappings DirectoryGroupMapping[]

  @@unique([parentId, code])
  @@index([path])
  @@index([parentId])
  @@index([type])
}

// Optional team ↔ org-unit link for default-attachment suggestions.
model TeamOrgUnit {
  id        String   @id @default(cuid())
  teamId    String
  orgUnitId String
  createdAt DateTime @default(now())

  team    Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  orgUnit OrgUnit @relation(fields: [orgUnitId], references: [id], onDelete: Cascade)

  @@unique([teamId, orgUnitId])
  @@index([orgUnitId])
}

// v2.9 (Phase 4): a person's membership in the BUSINESS dimension — which
// company/site/holding they belong to. This is the reversal Phase 5 makes
// explicit: OrgUnit membership + grants become access-relevant, while
// TeamOrgUnit (default-attachment suggestion) stays non-RBAC exactly as its
// comment says.
//
//   SYNC   — derived from a DirectoryGroupMapping.orgUnitId match; the sync
//            job owns the row (creates, and removes on unmatch)
//   MANUAL — placed by an admin for local users; the sync never touches it
//
// A person may belong to MULTIPLE org nodes (unlike units): someone can sit
// at a site and serve a company function. The Phase 4 exit criterion is
// ">= 1 node or on the exception report", not exactly one.
enum OrgMembershipSource {
  SYNC
  MANUAL
}

// v2.9 (Phase 5): a standing rule — "projects created under THIS org subtree
// auto-grant THAT subject". Applied ONCE at project creation; materialized
// grants are stamped sourcePolicyId so a bad policy is bulk-revocable, and
// deleting a policy never revokes retroactively (the stamp outlives it via
// SetNull… no — the stamp is a bare string precisely so it survives policy
// deletion for the revoke script).
//
// This is the recorded reversal of "the org tree is non-RBAC": it applies to
// OrgUnit membership + grants. TeamOrgUnit's non-RBAC comment stays true of
// that table.
model OrgUnitGrantPolicy {
  id              String              @id @default(cuid())
  name            String
  // Subtree anchor: applies to projects whose orgUnit sits at or below this
  // node (materialized-path prefix match — structurally incapable of crossing
  // roots).
  anchorOrgUnitId String
  subjectType     ProjectGrantSubject
  subjectId       String
  level           ProjectGrantLevel
  enabled         Boolean             @default(true)
  createdAt       DateTime            @default(now())

  anchor OrgUnit @relation("PolicyAnchor", fields: [anchorOrgUnitId], references: [id], onDelete: Cascade)

  @@index([anchorOrgUnitId, enabled])
}

model OrgUnitMembership {
  id        String              @id @default(cuid())
  orgUnitId String
  userId    String
  source    OrgMembershipSource @default(MANUAL)
  createdAt DateTime            @default(now())

  orgUnit OrgUnit @relation(fields: [orgUnitId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgUnitId, userId])
  @@index([userId])
}

// v1.50 / v1.51: team-scoped user groups for granting project access without
// changing project ownership. v1.51 adds cross-team invites + access levels.
// v2.6 (Phase 1A): groups now carry a `kind`.
//
//   COLLAB — the shipped behaviour, unchanged. Invitation-based, cross-team
//            members allowed, carries project grants. Every dotted line.
//   UNIT   — a section inside a department. AD-synced, direct membership (no
//            invitations), accessLevel pinned FULL, exactly ONE per person per
//            team. The smallest box whose manager assigns daily work.
//
// Default COLLAB so the migration needs zero backfill and every existing group
// keeps its exact semantics.
enum UserGroupKind {
  UNIT
  COLLAB
  // v2.16: an OPTIONAL subdivision inside a department (اداره within an
  // اداره کل). Carries no membership of its own — people stay members of the
  // DEPARTMENT (one-department constraint, assignment scoping and the sync
  // all untouched); a member is merely TAGGED with a sub-unit via
  // UserGroupMember.subUnitId.
  SUBUNIT
}

// v2.6 (Phase 1A): a member's standing WITHIN the group. Distinct from
// `accessLevel` (which is about project access) and from TeamRole (which is
// about the department). A UNIT's MANAGER is the supervisor who accepts unit
// participation in projects (Phase 3) and assigns work inside the unit.
enum GroupRole {
  MANAGER
  MEMBER
}

model UserGroup {
  id          String   @id @default(cuid())
  teamId      String
  name        String
  description String?
  // v2.6 (Phase 1A). See UserGroupKind.
  kind        UserGroupKind @default(COLLAB)
  // v2.16: SUBUNIT rows point at their parent DEPARTMENT. Cascade: deleting a
  // department removes its sub-units (they are meaningless without it).
  parentId    String?
  parent      UserGroup?  @relation("GroupSubUnits", fields: [parentId], references: [id], onDelete: Cascade)
  subUnits    UserGroup[] @relation("GroupSubUnits")
  taggedMembers UserGroupMember[] @relation("MemberSubUnit")
  // v1.98 (PMIS R2): optional per-group default project profile — the highest-
  // priority defaulting carrier (group ▸ team ▸ system NEUTRAL) the project-
  // create picker pre-fills from. SetNull so deleting the profile just clears
  // the default.
  defaultProfileId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team     Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  members  UserGroupMember[]
  grants   ProjectGroupGrant[]
  defaultProfile ProjectProfile? @relation("GroupDefaultProfile", fields: [defaultProfileId], references: [id], onDelete: SetNull)
  // v2.6 (Phase 1A, D-3): directory mappings that place people into this group.
  // Only meaningful for kind = UNIT; a COLLAB group is invitation-based.
  directoryMappings DirectoryGroupMapping[]

  @@unique([teamId, name])
  @@index([teamId])
}

model UserGroupMember {
  id          String            @id @default(cuid())
  groupId     String
  userId      String
  accessLevel GroupAccessLevel  @default(FULL)
  status      GroupInviteStatus @default(ACCEPTED)
  invitedById String?
  invitedAt   DateTime          @default(now())
  respondedAt DateTime?
  external    Boolean           @default(false)
  // v2.6 (Phase 1A): standing within the group. See GroupRole.
  role        GroupRole         @default(MEMBER)
  // v2.16: optional sub-unit tag. SetNull — deleting a sub-unit just untags
  // its people. Service-validated: the sub-unit's parent must be this row's
  // group (a department member cannot be tagged with another department's unit).
  subUnitId   String?
  subUnit     UserGroup?        @relation("MemberSubUnit", fields: [subUnitId], references: [id], onDelete: SetNull)

  // v2.6 (Phase 1A): DENORMALIZED from the parent group, and denormalized for
  // exactly one reason — the single-unit-per-person rule.
  //
  // That rule is "at most one UNIT membership per (user, team)". Enforcing it
  // in Postgres needs a partial unique index on (userId, teamId), but teamId
  // lives on UserGroup, and a partial index cannot reference another table.
  // There is no expression-join escape hatch. So the column is carried here.
  //
  // `isUnit` is likewise denormalized from UserGroup.kind, because the index
  // predicate cannot join either.
  //
  // Both are maintained by a trigger (see the migration) rather than by service
  // discipline: a denormalized column kept correct "by convention" is one
  // forgotten code path away from letting a person hold two units, which is the
  // exact thing the constraint exists to prevent.
  teamId      String?
  isUnit      Boolean           @default(false)

  group     UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User?     @relation("GroupInvitesSent", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([groupId, userId])
  @@index([userId, status])
  @@index([groupId])
  // The partial unique index that actually enforces one-unit-per-person is
  // raw SQL in the migration — Prisma cannot express a WHERE clause on an
  // index. This plain index supports the lookups that back it.
  @@index([userId, teamId, isUnit])
}

// v2.6 (Phase 2): the ONE grant table.
//
// Replaces six overlapping access paths with a single auditable record:
// ProjectGroupGrant, ProjectTeamShare, and the delegate *access* rung all
// collapse into rows here. Delegate *capabilities* (ProjectEditDelegate.
// capabilities) stay a separate concern — they are about which fields a person
// may edit, not whether they can reach the project at all.
//
// One table means one sharing panel, one audit export (ISO 27001 A.5.18), and
// one place to reason about who can see a project. Today that reasoning is
// spread across resolveProjectAccess plus three list-filter helpers that must
// be kept manually in agreement — a class of bug this removes rather than
// documents.
//
// ORG_UNIT is declared now but not resolved until Phase 5. Adding the enum
// value later would be a migration on live rows; adding it now is free.
enum ProjectGrantSubject {
  USER
  GROUP
  TEAM
  ORG_UNIT
}

enum ProjectGrantLevel {
  READ
  WRITE
}

// PENDING/DECLINED are declared now, used in Phase 3. Phase 2 writes ACTIVE
// only, so the flag transition changes no user-visible consent behaviour.
enum ProjectGrantStatus {
  PENDING
  ACTIVE
  DECLINED
}

// v-next (cross-unit assignment workflow): the target of an assignment request.
// A dedicated closed enum rather than reusing ProjectGrantSubject — it shares
// the GROUP/TEAM value NAMES for vocabulary alignment but deliberately excludes
// USER/ORG_UNIT, which are storable-but-meaningless as an assignment target.
enum AssignmentTargetType {
  GROUP // department = UserGroup kind UNIT
  TEAM // division
}

// v-next: TaskAssignmentRequest lifecycle. Terminal states: ASSIGNED, DECLINED,
// EXPIRED. FORWARDED is scenario C only (deputy → dept manager) and is itself
// non-terminal — it still resolves to ASSIGNED.
enum AssignmentRequestStatus {
  REQUESTED
  APPROVED
  FORWARDED
  ASSIGNED
  DECLINED
  EXPIRED
}

model ProjectAccessGrant {
  id          String              @id @default(cuid())
  projectId   String
  subjectType ProjectGrantSubject
  // Polymorphic: a User.id, UserGroup.id, Team.id, or OrgUnit.id depending on
  // subjectType. Deliberately NOT four nullable FK columns — that shape makes
  // "exactly one is set" a check constraint nobody maintains, and makes every
  // query a four-way coalesce. The cost is no referential integrity, so the
  // resolver treats an unresolvable subject as no-access and the access report
  // surfaces it (same posture as DirectoryGroupMapping.teamId today).
  subjectId   String
  level       ProjectGrantLevel
  status      ProjectGrantStatus  @default(ACTIVE)

  // Audit trail. `grantedById` is the human who did it — null for rows the
  // Phase 2 backfill created, which is exactly how you tell them apart.
  grantedById String?
  grantedAt   DateTime            @default(now())
  // Free-text provenance for backfilled rows ('backfill:group', 'backfill:team',
  // 'backfill:delegate') and, from Phase 5, 'policy'.
  source      String?
  // Phase 5 stamps the OrgUnitGrantPolicy that materialized this row, so a bad
  // policy can be bulk-revoked. Deleting a policy never revokes retroactively.
  sourcePolicyId String?
  // Null = never expires. Checked by the resolver, not by a cleanup job — an
  // expired grant must stop working immediately, not at the next sweep.
  expiresAt   DateTime?

  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  grantedBy   User?               @relation("ProjectGrantsIssued", fields: [grantedById], references: [id], onDelete: SetNull)

  // One grant per (project, subject, level). Two levels for the same subject
  // is legal and resolves to the higher — simpler than a partial index, and it
  // makes "upgrade READ to WRITE" an insert rather than an update race.
  @@unique([projectId, subjectType, subjectId, level])
  @@index([projectId, status])
  @@index([subjectType, subjectId, status])
  @@index([sourcePolicyId])
}

// v-next (cross-unit assignment workflow). A managed request to assign a task
// to someone outside the actor's org boundary: it routes to the responsible
// manager (dept manager for cross-department, deputy for cross-division), who
// selects the final assignee. See docs/ASSIGNMENT_WORKFLOW.md.
//
// Deliberately NOT a row on a shared Approval table — the codebase keeps each
// workflow's lifecycle its own (task completion approval, timesheet periods,
// grant consent all do). Unrelated to Task.approverId (the v1.87 completion
// gate) despite the vocabulary overlap.
model TaskAssignmentRequest {
  id            String   @id @default(cuid())
  // Tenancy invariant — every team-scoped row carries teamId (the project's
  // home division). The service re-asserts task↔project↔team on every read.
  teamId        String
  taskId        String
  projectId     String
  requesterId   String
  targetType    AssignmentTargetType
  // UserGroup.id (kind UNIT) when targetType=GROUP; Team.id when TEAM.
  targetId      String
  // Advisory candidate the requester proposes; the approver confirms or
  // overrides (D2 default — advisory only).
  proposedId    String?
  status        AssignmentRequestStatus @default(REQUESTED)
  // Who decided (dept manager for B, deputy for C). Null until first decision.
  approverId    String?
  // Scenario C: the dept manager a deputy forwarded (ابلاغ) the request to.
  forwardedToId String?
  // Final selection, set together with Task.assigneeId at the ASSIGNED step.
  assigneeId    String?
  declineReason String?
  // SLA horizon (working-day calendar, not naive +Nd). The P3 expiry scheduler
  // transitions REQUESTED/APPROVED/FORWARDED → EXPIRED past this.
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  decidedAt     DateTime?
  // v-next (P3): one-shot marker for the T-1 SLA reminder (mirrors
  // Task.dueNotifiedAt). Null = not yet reminded; the sweep stamps it once.
  remindedAt    DateTime?

  // Ownership relations only (task/project/team): Cascade so a purged task,
  // project, or division cannot strand a pending request. The five USER refs
  // (requester/approver/forwardedTo/assignee/proposed) stay bare FK strings —
  // re-asserted in the service — to avoid five back-relations on User for what
  // is audit provenance, matching the ProjectAccessGrant subject posture.
  task    Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  team    Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId, status])
  @@index([taskId])
  // Approver inbox: "requests targeting my unit awaiting a decision".
  @@index([targetType, targetId, status])
  // Requester outbox.
  @@index([requesterId, status])
}

model ProjectGroupGrant {
  projectId String
  groupId   String
  grantedAt DateTime @default(now())

  project Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  group   UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([projectId, groupId])
  @@index([groupId])
}

// v2.5.58: whole-team project sharing. The project stays owned by its home
// team (Project.teamId and the Task.teamId denormalization are untouched); a
// share mounts it into a guest team — the project appears in that team's list
// and EVERY member gets READONLY=READ or FULL=WRITE via resolveProjectAccess.
// Managed by global ADMINs only (PUT /teams/:teamId/projects/:projectId/team-shares).
model ProjectTeamShare {
  projectId   String
  teamId      String
  level       GroupAccessLevel
  createdById String?
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  team    Team    @relation("ProjectSharesForTeam", fields: [teamId], references: [id], onDelete: Cascade)

  @@id([projectId, teamId])
  @@index([teamId])
}

// v1.86: per-project "full-edit" delegation. The project owner (or a global
// ADMIN) names users who may edit ALL task/subtask fields on this project —
// crucially the manager-only date fields and the task.change_responsible-gated
// field — for THIS project only. Deliberately separate from project access
// (resolveProjectAccess) and group grants: WRITE/FULL must NOT silently bypass
// those field-level restrictions, so the elevation is its own explicit record.
model ProjectEditDelegate {
  projectId   String
  userId      String
  grantedById String?
  grantedAt   DateTime @default(now())
  // v1.88: granular per-delegate capabilities (replaces the old all-or-nothing
  // full-edit). Values: FULL | EDIT_TITLES | EDIT_DETAILS | EDIT_DATES |
  // CHANGE_RESPONSIBLE | DELETE_TASKS. FULL implies all of the others (and is
  // the migrated value for every pre-v1.88 delegate, so behavior is unchanged).
  // Enforced field-by-field in tasks/subtasksService; see lib/delegateCaps.ts.
  capabilities String[] @default([])

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation("ProjectEditDelegateUser", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy User?   @relation("ProjectEditDelegateGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)

  @@id([projectId, userId])
  @@index([userId])
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
  // 3-month cadence — useful for OKR/QBR rituals. Equivalent to MONTHLY
  // with interval=3 mathematically, but a first-class enum value lets the
  // UI show "Quarterly" instead of forcing admins to interpret 'every 3
  // months'.
  QUARTERLY
  YEARLY
}

// Recurrence rule attached to a source Task. When the scheduler ticks past
// `nextRunAt`, it spawns a fresh Task with `spawnedFromTemplateId` pointing
// back here. One template per task (`sourceTaskId` is unique). Disable
// without deleting by flipping `active`.
model TaskTemplate {
  id              String              @id @default(cuid())
  sourceTaskId    String              @unique
  frequency       RecurrenceFrequency
  interval        Int                 @default(1)
  // Optional weekday filter — only meaningful for WEEKLY. 0 = Sunday … 6 = Saturday.
  byWeekday       Int[]
  // First eligible spawn date — UTC midnight per the v1.1.3 calendar-date rules.
  startsOn        DateTime
  // Optional cutoff (inclusive). After this, the rule stops spawning.
  endsOn          DateTime?
  // Optional cap on total spawns. Null = no cap.
  maxCount        Int?
  // Offsets applied to the spawned Task: spawn date + N days = dueDate /
  // plannedDate. Null = don't copy that date field at all.
  dueOffsetDays     Int?
  plannedOffsetDays Int?
  // Next time the scheduler should consider this rule. Always UTC-midnight.
  nextRunAt       DateTime
  spawnedCount    Int                 @default(0)
  active          Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  sourceTask      Task                @relation("TaskTemplateSource", fields: [sourceTaskId], references: [id], onDelete: Cascade)
  spawnedTasks    Task[]              @relation("TaskSpawnedFrom")

  @@index([active, nextRunAt])
}

model Task {
  id          String       @id @default(cuid())
  projectId   String
  // Denormalized for tenant scoping; every query filters by teamId.
  teamId      String
  // creatorId is nullable + SetNull so a deleted user's tasks remain.
  // The frontend renders "(deleted user)" wherever the creator name appears.
  creatorId   String?
  assigneeId  String?
  // v1.19: "Responsible" — the person actually doing the work.
  // Defaults to the creator on task creation. Only team MANAGERS / global
  // ADMINs can change this field after the fact. Nullable + SetNull so
  // user deletes don't cascade-kill tasks.
  responsibleId String?
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  // v1.87: optional approval gate. When requiresApproval is true, "completing"
  // the task (moving it to DONE) by a non-finalizer routes it to
  // PENDING_APPROVAL until the approver (or a manager/admin) decides. approverId
  // is nullable + SetNull so a user delete doesn't cascade-kill the task.
  requiresApproval Boolean   @default(false)
  approverId       String?
  // Hard deadline — "must be done by". Powers the TASK_DUE scheduler.
  dueDate     DateTime?
  // v1.37: "started on" date. Nullable, UTC midnight (same convention as
  // dueDate / plannedDate / completedAt). Subject to the v1.18
  // date-edit-restriction gate. NOT included in the calendar feed —
  // deferred. NOT used by any reminder or report — informational only
  // for now.
  startDate   DateTime?
  // Team's target completion date — "we plan to be done by". Used by the
  // timeliness report; doesn't trigger TASK_DUE notifications (those are for
  // the hard deadline only).
  plannedDate DateTime?
  // When the task was actually completed. Auto-filled on first transition to
  // status=DONE if not explicitly set; the member can also set it manually
  // (back-dating) regardless of status. Renamed from doneAt in v1.2.
  completedAt DateTime?
  // When a TASK_DUE notification was last emitted for this task — used by the
  // scheduler to avoid re-notifying every tick. Reset to null whenever dueDate
  // changes so the next due date triggers a fresh reminder.
  dueNotifiedAt DateTime?
  // Phase 4: spawned-by-recurrence linkage. spawnedForPeriod is the ISO date
  // of the period this task fulfils (e.g. "2026-05-23"); the unique pair
  // (templateId, period) prevents a double-spawn on retried scheduler ticks.
  spawnedFromTemplateId String?
  spawnedForPeriod      String?
  // v1.42: optional task-level budget fields. Same shape as v1.41 Project
  // budgets — DECIMAL(18,2), nullable, non-negative CHECK constraints.
  // The SPA computes utilization on the client as Actual / Planned * 100.
  plannedBudget Decimal?    @db.Decimal(18, 2)
  actualSpent   Decimal?    @db.Decimal(18, 2)
  // v1.93 (PMIS R1 — neutral core): schedule baseline + actual execution dates
  // (UTC-midnight calendar dates; manager-gated like the other date fields) and a
  // stored 0–100 percent-complete for portfolio roll-up + future EVM. All additive:
  // dates nullable, percentComplete defaults 0 (a DB CHECK keeps it in 0..100).
  baselineStart DateTime?
  baselineEnd   DateTime?
  actualStart   DateTime?
  actualEnd     DateTime?
  percentComplete     Int                  @default(0)
  // v2.1.1 (PMIS R1 supplement): how percentComplete was last set.
  // MANUAL = stored value; FROM_CHILDREN = leaf-weighted rollup at call time;
  // FROM_STATUS = derived from task status. Defaults to FROM_CHILDREN so new
  // tasks roll up naturally; existing rows were backfilled to FROM_CHILDREN.
  percentCompleteMode PercentCompleteMode  @default(FROM_CHILDREN)
  // v1.97 (PMIS R1 — neutral core): WBS n-level tree. `parentId` is a self-
  // reference within the SAME project; a null parent is a WBS root. `wbsOrder`
  // sequences siblings. The outline code "1.2.3" is still DERIVED on read
  // (would require sibling resequencing on any insert/delete). wbsPath,
  // wbsDepth, and isSummary are MATERIALIZED so subtree queries and EVM
  // leaf-detection work at SQL level without a full DFS walk.
  parentId    String?
  wbsOrder    Int          @default(0)
  // Materialized ancestry path: "/{id}" for root, "{parent.path}/{id}" for
  // children. Set on create/move/restore; cleared tasks retain their last path.
  wbsPath     String?
  wbsDepth    Int          @default(0)
  // true iff this task has at least one live (non-deleted) child. Maintained
  // by tasksService on create/move/remove and trashService on restore/purge.
  isSummary   Boolean      @default(false)
  // v2.1 (PMIS R5 — scheduling): zero-duration milestone marker on the Gantt.
  isMilestone   Boolean      @default(false)
  milestoneKind String?
  position    Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  // v1.21: soft-delete. deletedAt = null means "live"; non-null means
  // "in trash". Every read query in the service layer filters on this.
  // Restoring sets it back to null; purging hard-deletes the row.
  deletedAt   DateTime?
  deletedById String?

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // v1.97 (PMIS R1): WBS self-relation. SetNull on parent delete so hard-
  // deleting/purging a summary task promotes its children to roots rather than
  // cascading the subtree away.
  parent      Task?        @relation("TaskWbs", fields: [parentId], references: [id], onDelete: SetNull)
  children    Task[]       @relation("TaskWbs")
  creator     User?        @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  responsible  User?        @relation("TaskResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)
  approver    User?        @relation("TaskApprover", fields: [approverId], references: [id], onDelete: SetNull)
  deletedBy   User?        @relation("TaskDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  subtasks    Subtask[]
  labels      TaskLabel[]
  attachments Attachment[]
  comments    Comment[]
  activities  Activity[]
  template          TaskTemplate? @relation("TaskTemplateSource")
  spawnedFromTemplate TaskTemplate? @relation("TaskSpawnedFrom", fields: [spawnedFromTemplateId], references: [id], onDelete: SetNull)
  // v1.29: dependency edges. `dependencies` are edges OUT of this task —
  // each row means "this task is blocked by row.dependsOn". `blockedTasks`
  // are edges IN — each row means "row.task is blocked by this task".
  // Both sides cascade on Task delete; the unique (taskId, dependsOnId)
  // constraint on TaskDependency prevents duplicate edges.
  dependencies TaskDependency[] @relation("TaskDependencyFrom")
  blockedTasks TaskDependency[] @relation("TaskDependencyTo")
  customFieldValues CustomFieldValue[]
  // v1.94 (PMIS R1): Consulted/Informed RACI assignments for this task.
  raci         TaskRaci[]
  // v2.0 (PMIS R4): this task as a WBS node for cost/time roll-up.
  timeEntries       TimeEntry[]
  budgetLines       BudgetLine[]
  actualCostEntries ActualCostEntry[]
  baselineEntries   BaselineEntry[]
  // v2.2 (PMIS R6): resource assignments.
  resourceAssignments ResourceAssignment[]
  // v2.5 (PMIS R9): NCR corrective task back-link.
  qualityNcrs         QualityNcr[] @relation("NcrCorrectiveTask")
  // v2.5.26 (W2.2): correspondence letters this task is linked to.
  correspondenceLinks CorrespondenceTask[]
  // v-next: cross-unit assignment requests targeting this task.
  taskAssignmentRequests TaskAssignmentRequest[]

  // v1.30: tsvector for full-text search. Managed by raw SQL — the column
  // is GENERATED ALWAYS AS STORED with a GIN index. Prisma never reads it
  // (it's @ignore-d on the client); the SearchService talks to it via
  // $queryRaw. Declared here so prisma migrate dev doesn't see drift.
  // Unsupported(...) auto-excludes the column from the Prisma client; the
  // SearchService talks to it via $queryRaw only.
  searchVector Unsupported("tsvector")?

  @@index([teamId, status])
  @@index([teamId, assigneeId])
  @@index([teamId, responsibleId])
  @@index([approverId])
  @@index([teamId, dueDate])
  @@index([teamId, deletedAt])
  // v1.30.10 (S-18): /reports/done + the CompletionTrend dashboard
  // chart filter on `completedAt >= now - Nd AND deletedAt IS NULL`.
  // Pre-v1.30.10 the planner sequentially scanned the team partition
  // on every render. This composite covers both predicates.
  @@index([teamId, completedAt])
  @@index([projectId, status, position])
  // v1.97 (PMIS R1): WBS tree reads load a project's children grouped by parent.
  @@index([projectId, parentId])
  // v2.1.1 (PMIS R1 supplement): subtree queries via wbsPath LIKE prefix.
  @@index([projectId, wbsPath])
  @@unique([spawnedFromTemplateId, spawnedForPeriod])
}

// v1.94 (PMIS R1 — neutral core): the Consulted / Informed RACI legs as a join
// table (Responsible + Accountable stay as scalar fields elsewhere). Cascade on
// task or user delete; a user holds at most one row per (task, role).
model TaskRaci {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  role      RaciRole
  createdAt DateTime @default(now())

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId, role])
  @@index([taskId])
  @@index([userId])
}

// v1.82: subtask progress status. Separate from TaskStatus (which is
// {TODO,IN_PROGRESS,REVIEW,DONE}) — subtasks use a different 5-state set with
// WAITING + DEFERRED and no REVIEW. `done` is KEPT and kept in sync with this
// (status DONE ⇔ done true) so the checkbox + "X of Y done" rollup keep working.
enum SubtaskStatus {
  NOT_STARTED
  IN_PROGRESS
  WAITING
  DEFERRED
  DONE
}

model Subtask {
  id           String    @id @default(cuid())
  taskId       String
  title        String
  done         Boolean   @default(false)
  // v1.82: progress status (5-state). Source of truth for completion; `done`
  // above is derived (DONE ⇔ true) by the service so legacy reads still work.
  status       SubtaskStatus @default(NOT_STARTED)
  // v1.19: Subtask responsible — same semantics as Task.responsibleId. Defaults
  // to creator on subtask creation; only team MANAGERS / global ADMINs can
  // change it. Nullable + SetNull.
  responsibleId String?
  // v1.42: Subtask assignee — distinct from responsible. Responsible is
  // RACI ("responsible for getting it done", manager-gated change);
  // assignee is the lighter-weight "who's working on this right now"
  // (anyone with project access can change). Mirrors Task.assigneeId.
  assigneeId   String?
  // v1.41: optional scheduling window. Anchored to UTC midnight (same
  // convention as Task.startDate / dueDate / plannedDate). Cross-field
  // rule "endDate >= startDate when both set" is enforced in the service
  // layer + DB CHECK constraint. Nullable so existing subtasks stay valid.
  startDate    DateTime?
  endDate      DateTime?
  position     Int       @default(0)
  task         Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  responsible   User?   @relation("SubtaskResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)
  assignee     User?   @relation("SubtaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([taskId, status])
  @@index([responsibleId])
  @@index([assigneeId])
}

// v2.5.28 (StandaloneTask, Option C): personal tasks that live entirely outside
// any project/team — quick capture for individual work. Its own status enum
// (separate lifecycle, like Subtask) and NO teamId: fully isolated from project
// machinery. Owner-scoped only; the owner is the sole reader/writer.
enum StandaloneTaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model StandaloneTask {
  id                String               @id @default(cuid())
  ownerId           String
  title             String
  description       String?
  status            StandaloneTaskStatus @default(TODO)
  // Reusing TaskPriority is a plain value-enum reuse, not machinery coupling.
  priority          TaskPriority?
  // Calendar-date convention (UTC-midnight, zone-neutral) — same as Task.dueDate.
  dueDate           DateTime?
  completedAt       DateTime?
  // Manual ordering within a status column (dense reshuffle on reorder).
  sortOrder         Int                  @default(0)
  // One-shot due-reminder marker; reset to null on dueDate change (mirrors Task).
  lastDueNotifiedAt DateTime?
  // v2.5.28 (D8): set when promoted to a real project Task. Deliberately a
  // PLAIN string, NOT a Prisma relation — isolation over referential integrity.
  promotedTaskId    String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  deletedAt         DateTime?

  owner User @relation("UserStandaloneTasks", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, deletedAt, status, sortOrder])
  @@index([ownerId, dueDate])
}

// v1.29: task dependency edges. `taskId` is the BLOCKED task; `dependsOnId`
// is the BLOCKER. Cycle prevention lives in the service layer (DFS reachability
// check before insert) — Postgres has no native cycle constraint and CHECK
// expressions can't traverse the table. Both FKs cascade so a deleted task
// tears its edges down with it.
model TaskDependency {
  id          String         @id @default(cuid())
  // Denormalized for tenant scoping, same as Task. Every read filters by
  // teamId so cross-tenant probes 404. Both endpoints of the edge must
  // share this teamId — enforced in the service layer.
  teamId      String
  taskId      String
  dependsOnId String
  type        DependencyType @default(FINISH_TO_START)
  // v2.1 (PMIS R5): signed lag/lead on the edge (+2d FS, -1d lead, etc.).
  lag          Int           @default(0)
  lagUnit      LagUnit       @default(DAY)
  calendarMode CalendarMode  @default(WORKING)
  createdAt   DateTime       @default(now())

  task      Task @relation("TaskDependencyFrom", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn Task @relation("TaskDependencyTo", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnId])
  @@index([teamId])
  @@index([dependsOnId])
}

model Label {
  id     String      @id @default(cuid())
  // v1.80: nullable. teamId = NULL → a GLOBAL "predefined" label: admin-managed,
  // visible and usable in EVERY team, read-only to members. Non-null → a team's
  // own user-defined label (unchanged behaviour). Uniqueness is enforced by two
  // PARTIAL unique indexes created in the migration — unique (teamId,name) for
  // team labels and unique (name) for globals — which Prisma can't express, so
  // @@unique is intentionally omitted here.
  teamId String?
  name   String
  color  String
  team   Team?       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tasks  TaskLabel[]
  projects ProjectLabel[]
}

model ProjectLabel {
  projectId String
  labelId   String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label     Label   @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([projectId, labelId])
  @@index([labelId])
}

model TaskLabel {
  taskId  String
  labelId String
  task    Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label   Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
  @@index([labelId])
}

// v1.58: team-scoped custom field definitions. Reusable across all projects
// in the team; per-task values live in CustomFieldValue. Project-scoped
// restriction is deferred to a future release.
model CustomFieldDefinition {
  id          String          @id @default(cuid())
  teamId      String
  name        String
  type        CustomFieldType
  description String?
  position    Int             @default(0)
  required    Boolean         @default(false)
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  team            Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  options         CustomFieldOption[]
  values          CustomFieldValue[]
  intakeFormFields IntakeFormField[]

  @@unique([teamId, name])
  @@index([teamId, active])
}

model CustomFieldOption {
  id       String  @id @default(cuid())
  fieldId  String
  label    String
  color    String?
  position Int     @default(0)

  field      CustomFieldDefinition     @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  selections CustomFieldValueOption[]

  @@unique([fieldId, label])
  @@index([fieldId])
}

// v1.58: typed per-task custom field values. One row per (field, task).
// Select values use CustomFieldValueOption join for filterable multi-select.
model CustomFieldValue {
  id          String    @id @default(cuid())
  fieldId     String
  taskId      String
  valueText   String?
  valueNumber Decimal?  @db.Decimal(18, 4)
  valueDate   DateTime?
  valueBool   Boolean?
  valueUserId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  field      CustomFieldDefinition     @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  task       Task                      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  valueUser  User?                     @relation("CustomFieldPerson", fields: [valueUserId], references: [id], onDelete: SetNull)
  selections CustomFieldValueOption[]

  @@unique([fieldId, taskId])
  @@index([taskId])
  @@index([fieldId])
}

model CustomFieldValueOption {
  valueId  String
  optionId String

  value  CustomFieldValue  @relation(fields: [valueId], references: [id], onDelete: Cascade)
  option CustomFieldOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@id([valueId, optionId])
  @@index([optionId])
}

// v1.67: team-scoped configurable dashboards — saved widget collections.
model Dashboard {
  id          String   @id @default(cuid())
  teamId      String
  ownerId     String
  name        String
  description String?
  shared      Boolean  @default(false)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team    Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  owner   User              @relation("DashboardOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  widgets DashboardWidget[]

  @@index([teamId])
  @@index([ownerId])
}

model DashboardWidget {
  id          String  @id @default(cuid())
  dashboardId String
  type        String
  title       String
  dataSource  String
  groupBy     String?
  timeBucket  String?
  filtersJson Json?
  configJson  Json?
  position    Int     @default(0)

  dashboard Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@index([dashboardId])
}

// v1.69: intake forms — map submissions to tasks in a chosen project.
model IntakeForm {
  id          String   @id @default(cuid())
  teamId      String
  projectId   String
  name        String
  description String?
  // TEAM = authenticated team members (default). PUBLIC = opaque-token URL.
  mode        String   @default("TEAM")
  publicToken String?  @unique
  enabled     Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team    Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator User?             @relation("IntakeFormCreator", fields: [createdById], references: [id], onDelete: SetNull)
  fields  IntakeFormField[]

  @@index([teamId])
  @@index([publicToken])
}

model IntakeFormField {
  id            String  @id @default(cuid())
  formId        String
  label         String
  // Built-in: title | description | priority | dueDate | assignee | labels
  // Custom: customField (requires customFieldId)
  target        String
  customFieldId String?
  required      Boolean @default(false)
  helpText      String?
  position      Int

  form        IntakeForm             @relation(fields: [formId], references: [id], onDelete: Cascade)
  customField CustomFieldDefinition? @relation(fields: [customFieldId], references: [id], onDelete: SetNull)

  @@index([formId])
}

model Attachment {
  id         String   @id @default(cuid())
  // v1.90: polymorphic parent — exactly one of taskId / correspondenceId is set
  // (enforced by a DB CHECK in the migration). taskId was previously required.
  taskId           String?
  correspondenceId String?
  uploaderId String
  // Display name shown in UI; never used to construct filesystem paths.
  filename   String
  // Opaque storage path on disk, generated by the server.
  storageKey String
  mimeType   String
  sizeBytes  Int
  createdAt  DateTime @default(now())
  task           Task?           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  correspondence Correspondence? @relation(fields: [correspondenceId], references: [id], onDelete: Cascade)
  // Cascade — when a user is deleted, their uploaded blobs are removed along
  // with the user account. The on-disk files are NOT cleaned up automatically;
  // a janitor task is the proper home for orphan-blob GC.
  uploader   User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([correspondenceId])
}

// v1.90: correspondence (دبیرخانه) — a per-project register of formal letters.
// Optional module, enabled per project by a global admin (Project.correspondenceEnabled).
model Correspondence {
  id              String                  @id @default(cuid())
  // teamId denormalized from the project for cheap multi-tenant filtering (like Task.teamId).
  teamId          String
  projectId       String
  direction       CorrespondenceDirection
  subject         String
  body            String?
  // v2.5.26 (W2.2): the counterpart org's own number/date on an incoming letter
  // (nullable/additive; externalDate follows the UTC-midnight calendar-date
  // convention like letterDate).
  externalReferenceNumber String?
  externalDate            DateTime?
  // v2.5.26 (W2.2): one-level "reply to" link to another letter in the SAME
  // project. Thread view is derived by walking the chain — no thread table.
  // SetNull so deleting the parent doesn't cascade the reply away.
  replyToId       String?
  // UTC-midnight instant for a Jalali calendar date (same convention as Task date fields).
  letterDate      DateTime
  // Jalali year derived from letterDate at create; the auto-number reset key.
  jalaliYear      Int
  // Sequential ordinal within (projectId, jalaliYear); backs referenceNumber.
  sequence        Int
  // Human reference "{jy}-{NNN}", e.g. "1404-001". Permanent once issued.
  referenceNumber String
  status          CorrespondenceStatus    @default(DRAFT)
  senderId        String?
  recipientId     String?
  createdById     String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  deletedAt       DateTime?
  deletedById     String?

  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sender    Contact? @relation("CorrespondenceSender", fields: [senderId], references: [id], onDelete: SetNull)
  recipient Contact? @relation("CorrespondenceRecipient", fields: [recipientId], references: [id], onDelete: SetNull)
  createdBy User?    @relation("CorrespondenceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  deletedBy User?    @relation("CorrespondenceDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  // v2.5.26 (W2.2): reply-to self-relation (one level; thread derived by walking).
  replyTo   Correspondence?  @relation("CorrespondenceReplyTo", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   Correspondence[] @relation("CorrespondenceReplyTo")

  referrals   CorrespondenceReferral[]
  attachments Attachment[]
  // v2.5.26 (W2.2): letter↔task bridge (many tasks per letter).
  linkedTasks CorrespondenceTask[]

  // v2.5.30 (W2.3): tsvector for full-text search (generated STORED column
  // managed by raw SQL in the migration — see Task.searchVector). Unsupported()
  // keeps it off the generated client; the service queries it via raw SQL.
  searchVector Unsupported("tsvector")?

  @@unique([projectId, jalaliYear, sequence])
  @@unique([projectId, referenceNumber])
  @@index([teamId])
  @@index([projectId, deletedAt, letterDate])
  @@index([projectId, status])
  @@index([replyToId])
}

// v1.90: referral (ارجاع) of a letter to a team member for ACTION or INFO.
model CorrespondenceReferral {
  id               String         @id @default(cuid())
  correspondenceId String
  teamId           String
  userId           String
  kind             ReferralKind   @default(ACTION)
  note             String?
  status           ReferralStatus @default(PENDING)
  referredById     String?
  // v2.5.26 (W2.2): optional action-by date (calendar-date convention). Powers
  // the cross-project "My referrals" inbox overdue/this-week filters + W3 reminders.
  dueAt            DateTime?
  createdAt        DateTime       @default(now())
  handledAt        DateTime?

  correspondence Correspondence @relation(fields: [correspondenceId], references: [id], onDelete: Cascade)
  team           Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user           User           @relation("ReferralRecipient", fields: [userId], references: [id], onDelete: Cascade)
  referredBy     User?          @relation("ReferralReferredBy", fields: [referredById], references: [id], onDelete: SetNull)

  @@unique([correspondenceId, userId])
  @@index([userId, status])
  @@index([userId, status, dueAt])
  @@index([correspondenceId])
}

// v2.5.26 (W2.2): letter↔task bridge. Keeps Task untouched; many tasks per
// letter, and the link itself is auditable. Both FKs cascade so deleting either
// side tears the link down. Composite PK doubles as the uniqueness guarantee.
model CorrespondenceTask {
  correspondenceId String
  taskId           String
  createdById      String?
  createdAt        DateTime @default(now())

  correspondence Correspondence @relation(fields: [correspondenceId], references: [id], onDelete: Cascade)
  task           Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@id([correspondenceId, taskId])
  @@index([taskId])
}

// v1.90: per-(project, Jalali year) sequence backing correspondence reference numbers.
model CorrespondenceCounter {
  id           String @id @default(cuid())
  projectId    String
  jalaliYear   Int
  currentValue Int    @default(0)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, jalaliYear])
}

// v1.90: team-level reusable contacts directory (letter senders/recipients).
model Contact {
  id           String      @id @default(cuid())
  teamId       String
  name         String
  organization String?
  email        String?
  phone        String?
  type         ContactType @default(PERSON)
  createdById  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?

  team      Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy User? @relation("ContactCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  sentLetters     Correspondence[] @relation("CorrespondenceSender")
  receivedLetters Correspondence[] @relation("CorrespondenceRecipient")

  @@index([teamId, deletedAt])
  @@index([teamId, name])
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  // authorId nullable + SetNull so a deleted user's comments survive.
  authorId  String?
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // v1.21: soft-delete. Same shape as Task — null = live; set = in trash.
  deletedAt   DateTime?
  deletedById String?
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  deletedBy User?    @relation("CommentDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)

  // v1.30: tsvector for full-text search. See Task.searchVector for
  // rationale + lifecycle (managed by raw SQL, never read via Prisma).
  // Unsupported(...) auto-excludes the column from the Prisma client; the
  // SearchService talks to it via $queryRaw only.
  searchVector Unsupported("tsvector")?

  @@index([taskId, createdAt])
  @@index([taskId, deletedAt])
}

model Activity {
  id        String   @id @default(cuid())
  // Phase 3A: taskId is now nullable. Future event types (directory.created,
  // user.provisioned, auth.2fa_enabled, token.created) don't belong to a
  // task; teamId or neither is set instead.
  taskId    String?
  // Denormalized team scope. Filled by logActivity at write time — either
  // explicitly by the caller, or auto-resolved from Task.teamId when only
  // taskId is supplied. Indexed for the team-scoped audit-log query.
  teamId    String?
  // Phase 3A: nullable so system-emitted events (scheduler, SCIM
  // auto-provision) have no human actor. SetNull on user delete preserves
  // the row for audit forensics — the audit log is the one place where
  // "(deleted user) did X" is more useful than dropping the row.
  actorId   String?
  action    String
  meta      Json
  createdAt DateTime @default(now())
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  team      Team?    @relation("TeamActivity", fields: [teamId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([teamId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
}

// Server-to-server API token. Authenticates as `ownerId`; the token's
// scopes are advisory in Phase 3B (request.user reflects the owner, so
// permission falls out of the owner's GlobalRole + TeamMembership). The
// raw token surfaces ONCE at generate; only sha256(rawToken) persists.
model ApiToken {
  id         String    @id @default(cuid())
  ownerId    String
  name       String
  // First 8 chars of the raw token, shown in the UI to disambiguate
  // multiple tokens (e.g. "th_a1b2c3d4…"). Not security-sensitive.
  prefix     String
  tokenHash  String    @unique
  // Free-form strings — convention is `<resource>:<action>` (e.g.
  // "tasks:read") or "*" for full access.
  scopes     String[]
  expiresAt  DateTime?
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  owner      User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}

// Outbound webhook subscription. teamId-scoped so a directory-managed
// team's automations don't leak into another tenant. `secretEnc` is the
// AES-256-GCM ciphertext of the signing secret used for HMAC headers.
model Webhook {
  id        String   @id @default(cuid())
  teamId    String
  name      String
  url       String
  // The HMAC signing secret. Stored encrypted; surfaced once at creation
  // if the caller didn't supply their own.
  secretEnc String
  // Subscribed event types — e.g. ["task.created","comment.added"] or ["*"].
  events    String[]
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([teamId])
}

// One row per outbound delivery attempt cluster. The dispatcher polls
// (status=PENDING AND nextAttemptAt<=now) and updates status + attempt
// + nextAttemptAt as it works. Acts as both a delivery log and the queue.
model WebhookDelivery {
  id            String                @id @default(cuid())
  webhookId     String
  eventType     String
  payload       Json
  status        WebhookDeliveryStatus @default(PENDING)
  attempt       Int                   @default(0)
  maxAttempts   Int                   @default(5)
  httpStatus    Int?
  errorMessage  String?
  nextAttemptAt DateTime              @default(now())
  deliveredAt   DateTime?
  createdAt     DateTime              @default(now())
  webhook       Webhook               @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt])
  @@index([webhookId, createdAt])
}

// v1.62: instance-wide calendar holidays — specific-date off-days distinct
// from recurring weekend weekdays (calendar.weekend InstanceSetting).
// Dates are UTC midnight calendar anchors (same rule as task dueDate).
model Holiday {
  id          String        @id @default(cuid())
  date        DateTime
  name        String
  recurring   Boolean       @default(false)
  source      HolidaySource @default(MANUAL)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  createdById String?
  createdBy   User?         @relation("HolidayCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([date])
  @@index([date])
}

// Global instance configuration. Key-value store for toggles that apply to
// the whole deployment (e.g. "registration.public", "smtp.from"). Reads +
// writes are restricted to GlobalRole.ADMIN at the route layer. Schema kept
// deliberately loose (Json value) so future settings don't need a migration
// each time; the API layer enforces shape per-key via Zod.
model InstanceSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
  // Audit trail: which admin last touched this key. Nullable so a deleted
  // admin's row doesn't cascade-delete the setting itself.
  updatedBy String?
}

model Notification {
  id        String     @id @default(cuid())
  userId    String
  // v2.5.28: nullable — personal (standalone) task notifications have no team.
  // Team-scoped notifications still always carry teamId; the list query filters
  // by userId only, so null-team rows surface correctly for their owner.
  teamId    String?
  type      NotifyType
  payload   Json
  readAt    DateTime?
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team?      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

// v1.60: no-code automation rules — team-scoped trigger → conditions → actions.
model AutomationRule {
  id             String   @id @default(cuid())
  teamId         String
  name           String
  description    String?
  enabled        Boolean  @default(true)
  triggerType    String
  conditionMatch String   @default("ALL")
  position       Int      @default(0)
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  team           Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  conditions     AutomationCondition[]
  actions        AutomationAction[]
  runs           AutomationRun[]

  @@index([teamId, enabled, triggerType])
}

model AutomationCondition {
  id            String         @id @default(cuid())
  ruleId        String
  factType      String
  operator      String
  valueJson     Json?
  customFieldId String?
  rule          AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
}

model AutomationAction {
  id            String         @id @default(cuid())
  ruleId        String
  actionType    String
  valueJson     Json?
  customFieldId String?
  position      Int            @default(0)
  rule          AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
}

model AutomationRun {
  id          String         @id @default(cuid())
  ruleId      String
  taskId      String
  triggerType String
  status      String
  detail      String?
  createdAt   DateTime       @default(now())
  rule        AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId, createdAt])
  @@index([taskId])
}

// ============================================================================
// v2.0 (PMIS R4 — Cost Control + Time Tracking). Two profile-gated modules:
//   timesheets   — RateCard, TimesheetPeriod, TimeEntry
//   cost_control — CostAccount (CBS), BudgetLine, Commitment, Expense,
//                  ActualCostEntry (the append-only canonical AC ledger)
// All money is stored as INTEGER minor units (`amountMinor: BigInt`) + a
// Currency, per the R0 money convention (lib/money.ts). Cross-currency roll-up
// uses FxRate → a snapshotted `baseAmountMinor` in the team reportingCurrency.
// Everything is additive: existing projects backfill to a DEFAULT cost account
// + one MIGRATED budget line from their legacy `plannedBudget`.
// ============================================================================

enum RateScope {
  USER
  ROLE
}

// Timesheet period lifecycle. Mirrors the task approval vocabulary (there is no
// shared Approval table) but lives on the period: OPEN→SUBMITTED→APPROVED|REJECTED,
// REJECTED/APPROVED→REOPENED (a manager re-opens to allow edits). Entries are
// only editable while the owning period is OPEN or REOPENED (or has no period).
enum TimesheetStatus {
  OPEN
  SUBMITTED
  APPROVED
  REJECTED
  REOPENED
}

enum BudgetLineSource {
  MIGRATED
  MANUAL
}

enum CommitmentStatus {
  OPEN
  CLOSED
  CANCELLED
}

// Where an actual-cost ledger entry came from. TIMESHEET/EXPENSE are posted by
// approval flows; MANUAL/INVOICE by a cost manager. Corrections never edit a
// row — they post a reversing entry (reversalOfId set, amount negated).
enum CostEntrySource {
  TIMESHEET
  EXPENSE
  INVOICE
  MANUAL
}

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

// Cost/bill rate for a user (or a team role). The active rate at a TimeEntry's
// date is SNAPSHOTTED onto the entry so historical actuals never drift when a
// rate changes. `effectiveTo` null = open-ended.
model RateCard {
  id            String    @id @default(cuid())
  teamId        String
  scope         RateScope
  userId        String?
  role          TeamRole?
  costRateMinor BigInt
  billRateMinor BigInt?
  currency      Currency
  effectiveFrom DateTime  @db.Date
  effectiveTo   DateTime? @db.Date
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  team Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([teamId, scope])
  @@index([userId])
}

model TimesheetPeriod {
  id              String          @id @default(cuid())
  teamId          String
  userId          String
  periodStart     DateTime        @db.Date
  periodEnd       DateTime        @db.Date
  status          TimesheetStatus @default(OPEN)
  submittedAt     DateTime?
  decidedAt       DateTime?
  // Audit-only stamp; not an FK (mirrors how other audit ids are kept).
  decidedById     String?
  rejectionReason String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  team    Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries TimeEntry[]

  @@unique([userId, periodStart])
  @@index([teamId, userId])
  @@index([status])
}

model TimeEntry {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  projectId String
  // Optional WBS node (a Task) the time is booked against.
  taskId   String?
  periodId String?
  date     DateTime @db.Date
  minutes  Int
  billable Boolean  @default(true)
  note     String?
  // Cost rate snapshotted from the active RateCard at create time (null when no
  // rate is on file → the entry contributes hours but no labour cost).
  costRateMinorSnapshot BigInt?
  currencySnapshot      Currency?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team    Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user    User             @relation("TimeEntryUser", fields: [userId], references: [id], onDelete: Cascade)
  project Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task    Task?            @relation(fields: [taskId], references: [id], onDelete: SetNull)
  period  TimesheetPeriod? @relation(fields: [periodId], references: [id], onDelete: SetNull)

  @@index([teamId, projectId])
  @@index([userId, date])
  @@index([periodId])
  @@index([taskId])
}

// Cost Breakdown Structure node. A per-project tree (materialized `path`, same
// idiom as OrgUnit). Every project gets a seeded DEFAULT root at first use /
// migration. `taskId` optionally pins an account to a WBS node.
model CostAccount {
  id        String  @id @default(cuid())
  teamId    String
  projectId String
  parentId  String?
  code      String
  name      String
  path      String
  isDefault Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team     Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project  Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent   CostAccount?  @relation("CostAccountTree", fields: [parentId], references: [id], onDelete: Restrict)
  children CostAccount[] @relation("CostAccountTree")
  budgetLines       BudgetLine[]
  commitments       Commitment[]
  actualCostEntries ActualCostEntry[]
  expenses          Expense[]

  @@unique([projectId, code])
  @@index([teamId])
  @@index([projectId])
  @@index([parentId])
}

// Planned value (PV source): a budgeted amount on a cost account (optionally a
// WBS node). The budget report sums these instead of the legacy plannedBudget.
model BudgetLine {
  id            String           @id @default(cuid())
  teamId        String
  projectId     String
  costAccountId String
  taskId        String?
  amountMinor   BigInt
  currency      Currency
  source        BudgetLineSource @default(MANUAL)
  note          String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  team        Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  costAccount CostAccount @relation(fields: [costAccountId], references: [id], onDelete: Restrict)
  task        Task?       @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([costAccountId])
  @@index([teamId, currency])
}

// A committed-but-not-yet-actual obligation (e.g. a PO). Manual in R4; R9
// procurement will emit these automatically (procurementRefId reserved).
model Commitment {
  id              String           @id @default(cuid())
  teamId          String
  projectId       String
  costAccountId   String?
  vendorName      String?
  reference       String?
  amountMinor     BigInt
  currency        Currency
  status          CommitmentStatus @default(OPEN)
  procurementRefId String?
  incurredOn      DateTime?        @db.Date
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  team        Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  costAccount CostAccount? @relation(fields: [costAccountId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([costAccountId])
  @@index([status])
}

// A cost incurred by a person/expense report. On APPROVE it posts an
// ActualCostEntry(source=EXPENSE). Simple per-row status machine.
model Expense {
  id            String        @id @default(cuid())
  teamId        String
  projectId     String
  costAccountId String?
  taskId        String?
  amountMinor   BigInt
  currency      Currency
  status        ExpenseStatus @default(DRAFT)
  description   String?
  incurredOn    DateTime      @db.Date
  // Audit-only stamps (not FKs).
  submittedById String?
  decidedById   String?
  decidedAt     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  team        Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  costAccount CostAccount? @relation(fields: [costAccountId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([status])
  @@index([costAccountId])
}

// The canonical, APPEND-ONLY actual-cost ledger. `baseAmountMinor` is `amountMinor`
// converted to the team reportingCurrency via FxRate at post time (snapshotted).
// Corrections post a reversing row (reversalOfId set, amount negated) — rows are
// never updated or deleted.
model ActualCostEntry {
  id            String          @id @default(cuid())
  teamId        String
  projectId     String
  costAccountId String?
  taskId        String?
  source        CostEntrySource
  amountMinor   BigInt
  currency      Currency
  baseAmountMinor BigInt
  baseCurrency  Currency
  fxRateId      String?
  incurredOn    DateTime        @db.Date
  description   String?
  reversalOfId  String?
  // Soft links back to the originating row (not FKs — the ledger is canonical).
  sourceTimeEntryId String?
  sourceExpenseId   String?
  createdById   String?
  createdAt     DateTime        @default(now())

  team        Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  costAccount CostAccount?      @relation(fields: [costAccountId], references: [id], onDelete: SetNull)
  task        Task?             @relation(fields: [taskId], references: [id], onDelete: SetNull)
  reversalOf  ActualCostEntry?  @relation("ActualReversal", fields: [reversalOfId], references: [id], onDelete: SetNull)
  reversedBy  ActualCostEntry[] @relation("ActualReversal")

  @@index([projectId])
  @@index([costAccountId])
  @@index([teamId, incurredOn])
  @@index([source])
  @@index([taskId])
}

// ─── R6: Resource Management ────────────────────────────────────────────────

enum ResourceType {
  HUMAN
  EQUIPMENT
  MATERIAL
}

// v2.2 (PMIS R6): catalog of team resources (people, equipment, materials).
// HUMAN resources optionally link to a TaskHub User via userId.
model Resource {
  id            String       @id @default(cuid())
  teamId        String
  name          String
  type          ResourceType @default(HUMAN)
  userId        String?
  email         String?
  // Capacity fraction: 1.0 = full-time, 0.5 = half-time.
  maxUnits      Float        @default(1.0)
  costRateMinor BigInt?
  currency      Currency?
  calendarId    String?
  notes         String?
  deletedAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  team     Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  calendar CapacityCalendar? @relation(fields: [calendarId], references: [id], onDelete: SetNull)

  skills      ResourceSkill[]
  assignments ResourceAssignment[]

  @@unique([teamId, name])
  @@index([teamId, deletedAt])
  @@index([userId])
  @@index([calendarId])
}

model Skill {
  id        String   @id @default(cuid())
  teamId    String
  name      String
  createdAt DateTime @default(now())

  team      Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  resources ResourceSkill[]

  @@unique([teamId, name])
  @@index([teamId])
}

model ResourceSkill {
  resourceId String
  skillId    String
  level      Int    @default(1)

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  skill    Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([resourceId, skillId])
}

// Assignment of a resource to a WBS task. `units` = fraction of maxUnits.
model ResourceAssignment {
  id           String   @id @default(cuid())
  teamId       String
  projectId    String
  taskId       String
  resourceId   String
  units        Float    @default(1.0)
  plannedHours Float?
  actualHours  Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([taskId, resourceId])
  @@index([teamId])
  @@index([resourceId])
  @@index([projectId])
  @@index([taskId])
}

// ─── R7: EVM ────────────────────────────────────────────────────────────────

enum EacMethod {
  CPI_BASED
  SPI_BASED
  TCPI_BASED
}

// v2.3 (PMIS R7): earned-value metrics snapshot. On-demand computation is in
// EvmService; snapshots are saved here for S-curve trending.
model EvmSnapshot {
  id           String    @id @default(cuid())
  teamId       String
  projectId    String
  snapshotDate DateTime  @db.Date
  bac          BigInt
  pv           BigInt
  ev           BigInt
  ac           BigInt
  cv           BigInt
  sv           BigInt
  cpi          Decimal   @db.Decimal(6, 4)
  spi          Decimal   @db.Decimal(6, 4)
  eac          BigInt
  eacMethod    EacMethod @default(CPI_BASED)
  vac          BigInt
  tcpi         Decimal   @db.Decimal(6, 4)
  currency     Currency
  createdAt    DateTime  @default(now())

  team    Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, snapshotDate])
  @@index([teamId])
}

// ─── R8: PMIS Record Framework ──────────────────────────────────────────────

enum RecordTypeKind {
  BUILTIN
  CUSTOM
}

// v2.4 (PMIS R8): configurable record type (Issue, RFI, Document, Stakeholder, MoM, …).
// Built-in types are seeded at migration; teams can add CUSTOM types.
model PmisRecordType {
  id          String         @id @default(cuid())
  teamId      String?
  key         String
  name        String
  kind        RecordTypeKind @default(CUSTOM)
  statusSet   Json           @default("[]")
  transitions Json           @default("[]")
  position    Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  team    Team?        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  records PmisRecord[]

  @@unique([teamId, key])
  @@index([teamId])
}

// v2.4 (PMIS R8): a record instance (e.g. a single issue, RFI, document).
model PmisRecord {
  id           String   @id @default(cuid())
  teamId       String
  projectId    String
  recordTypeId String
  reference    String
  title        String
  description  String?
  status       String   @default("OPEN")
  fieldValues  Json     @default("{}")
  assigneeId   String?
  dueDate      DateTime?
  closedAt     DateTime?
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  team       Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  recordType PmisRecordType @relation(fields: [recordTypeId], references: [id], onDelete: Restrict)
  assignee   User?          @relation("PmisRecordAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy  User?          @relation("PmisRecordCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  comments   PmisRecordComment[]

  @@unique([projectId, reference])
  @@index([teamId])
  @@index([projectId, recordTypeId])
  @@index([projectId, status])
  @@index([assigneeId])
}

model PmisRecordComment {
  id        String   @id @default(cuid())
  recordId  String
  authorId  String?
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  record PmisRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  author User?      @relation("PmisRecordCommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([recordId, createdAt])
}

// ─── R9: Specialized Lifecycle ──────────────────────────────────────────────

enum RiskResponse {
  ACCEPT
  AVOID
  MITIGATE
  TRANSFER
}

enum ChangeRequestStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  APPLIED
}

enum ContractStatus {
  DRAFT
  ACTIVE
  CLOSED
  CANCELLED
}

enum PoStatus {
  DRAFT
  ISSUED
  PARTIALLY_RECEIVED
  RECEIVED
  CLOSED
  CANCELLED
}

enum NcrSeverity {
  MINOR
  MAJOR
  CRITICAL
}

enum NcrDisposition {
  USE_AS_IS
  REWORK
  REJECT
  CONCESSION
}

// v2.5 (PMIS R9): project risk register item.
model RiskRecord {
  id             String       @id @default(cuid())
  teamId         String
  projectId      String
  reference      String
  title          String
  description    String?
  probability    Int
  impact         Int
  score          Int
  response       RiskResponse @default(ACCEPT)
  mitigationPlan String?
  ownerId        String?
  dueDate        DateTime?
  closedAt       DateTime?
  createdById    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner     User?    @relation("RiskOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdBy User?    @relation("RiskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([projectId, reference])
  @@index([teamId])
  @@index([projectId, score])
}

// v2.5 (PMIS R9): change request. When APPROVED + applied, captures a new
// baseline (source=CHANGE_REQUEST) and posts a cost-ledger delta entry.
model ChangeRequest {
  id                String              @id @default(cuid())
  teamId            String
  projectId         String
  reference         String
  title             String
  description       String?
  status            ChangeRequestStatus @default(DRAFT)
  scheduleDeltaDays Int?
  costImpactMinor   BigInt?
  costCurrency      Currency?
  submittedById     String?
  submittedAt       DateTime?
  decidedById       String?
  decidedAt         DateTime?
  rejectionReason   String?
  appliedBaselineId String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  submittedBy User?    @relation("CrSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  decidedBy   User?    @relation("CrDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)

  @@unique([projectId, reference])
  @@index([teamId])
  @@index([projectId, status])
}

// v2.5 (PMIS R9): team-level vendor master for procurement.
model Vendor {
  id           String    @id @default(cuid())
  teamId       String
  name         String
  contactEmail String?
  contactPhone String?
  address      String?
  notes        String?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  team      Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  contracts Contract[]

  @@unique([teamId, name])
  @@index([teamId, deletedAt])
}

// v2.5 (PMIS R9): project-level contract with a vendor.
model Contract {
  id          String         @id @default(cuid())
  teamId      String
  projectId   String
  vendorId    String?
  reference   String
  title       String
  status      ContractStatus @default(DRAFT)
  valueMinor  BigInt?
  currency    Currency?
  startDate   DateTime?
  endDate     DateTime?
  notes       String?
  createdById String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  team      Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendor    Vendor?          @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  createdBy User?            @relation("ContractCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  pos       PurchaseOrder[]

  @@unique([projectId, reference])
  @@index([teamId])
  @@index([projectId, status])
  @@index([vendorId])
}

// v2.5 (PMIS R9): purchase order. On ISSUED, a Commitment is auto-posted in
// the cost module and commitmentId records the link.
model PurchaseOrder {
  id           String    @id @default(cuid())
  teamId       String
  projectId    String
  contractId   String?
  reference    String
  title        String
  status       PoStatus  @default(DRAFT)
  amountMinor  BigInt?
  currency     Currency?
  issuedDate   DateTime?
  expectedDate DateTime?
  receivedDate DateTime?
  commitmentId String?
  createdById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  team      Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contract  Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  createdBy User?     @relation("PoCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([projectId, reference])
  @@index([teamId])
  @@index([projectId, status])
  @@index([contractId])
}

// v2.5 (PMIS R9): quality non-conformance report.
// When disposition=REWORK a corrective-action task can be linked.
model QualityNcr {
  id               String          @id @default(cuid())
  teamId           String
  projectId        String
  reference        String
  title            String
  description      String?
  severity         NcrSeverity     @default(MINOR)
  disposition      NcrDisposition?
  correctiveTaskId String?
  closedAt         DateTime?
  createdById      String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  team           Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  correctiveTask Task?    @relation("NcrCorrectiveTask", fields: [correctiveTaskId], references: [id], onDelete: SetNull)
  createdBy      User?    @relation("NcrCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([projectId, reference])
  @@index([teamId])
  @@index([projectId, severity])
  @@index([correctiveTaskId])
}
