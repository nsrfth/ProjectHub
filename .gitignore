# dependencies
node_modules/
.pnpm-store/

# build output
dist/
build/
*.tsbuildinfo

# env
.env
.env.local
.env.*.local
.env.bak.*

# Leftover from a prior history-rewrite session — local-only safety copy
.git.backup-before-rewrite/

# Ephemeral commit-message scratch files used by docker-run-git pipelines.
commitmsg.tmp
.commitmsg.tmp

# logs
*.log
npm-debug.log*
pnpm-debug.log*

# editor
.vscode/
.idea/
*.swp
.DS_Store

# uploads (mounted volume)
backend/uploads/*
!backend/uploads/.gitkeep

# test / coverage
coverage/
.nyc_output/

# prisma
backend/prisma/*.db

# Claude Code session metadata (user-local, never relevant to others)
.claude/

# USER_MANUAL{,.fa}.md are canonical at the repo root; the copies under
# frontend/public are committed mirrors (so GitHub and the in-app /help route
# show the same content). Re-run `npm run sync-manual` after editing the root
# files, and commit the regenerated copies alongside.
DIAGNOSTIC_REPORT.md
docs/PMIS_ROADMAP.md
